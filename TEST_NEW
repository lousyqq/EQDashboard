        // 遞迴產生樹狀結構 HTML
        function buildTree(parentId) {
            const children = menus.filter(m => m.parentId === parentId);
            if (children.length === 0) return '';
            
            // 若為子層級，加上左側邊線與縮排
            let html = `<ul class="list-unstyled ${parentId ? 'ms-4 border-start border-2 border-primary border-opacity-25 ps-3 mt-2' : ''}">`;
            
