    function editPersonalMenu(id) {
        const menus = getCustomMenus();
        const m = menus.find(x => x.id === id); if(!m) return;
        let pSets = getPersonalSettings(currentUser.id);
        
        const isHidden = pSets[id] ? pSets[id].hidden : false;
        const target = pSets[id] ? (pSets[id].target || m.target || 'iframe') : (m.target || 'iframe');
        const icon = pSets[id] ? (pSets[id].icon || m.icon || '') : (m.icon || '');
        
        document.getElementById('editPersonalMenuId').value = id;
        document.getElementById('personalMenuName').value = m.displayName;
        document.getElementById('personalMenuVisible').checked = !isHidden;
        document.getElementById('personalMenuIcon').value = icon;
        
        const hasChildren = menus.some(child => child.parentId === id);
        document.getElementById('personalTargetGroup').style.display = hasChildren ? 'none' : 'block';
