    function savePersonalMenu(e) {
        e.preventDefault();
        const id = document.getElementById('editPersonalMenuId').value;
        if(!id) return;
        
        let pSets = getPersonalSettings(currentUser.id);
        if(!pSets[id]) pSets[id] = {};
        
        pSets[id].hidden = !document.getElementById('personalMenuVisible').checked;
        pSets[id].icon = document.getElementById('personalMenuIcon').value;
        pSets[id].target = document.getElementById('personalMenuTarget').value;
        
        savePersonalSettings(currentUser.id, pSets);
        if(modals.personalMenu) modals.personalMenu.hide();
        
        if(pendingPerSets && pendingPerSets[id]) {
            pendingPerSets[id] = pSets[id];
        }

        renderPersonalMenuManage(); 
        renderSidebarMenus(); 
    }

