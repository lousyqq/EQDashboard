            if (i18n[lang] && i18n[lang][key]) el.innerHTML = i18n[lang][key];
        });
        const langCodes = { 'zh': 'ZH', 'en': 'EN', 'ja': 'JA' };
        const langEl = document.getElementById('current-lang-code');
        if(langEl) langEl.innerText = langCodes[lang];
        
