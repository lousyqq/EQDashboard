                <td class="text-start"><div class="fw-bold text-primary">${m.displayName}</div></td>
                <td>${modeMap[modeType]}</td>
                <td class="small text-muted text-start" style="max-width: 200px; word-break: break-all;">${urlHtml}</td>
                <td>${targetHtml}</td>
                <td>${iconHtml}</td>
                <td ${noDrag}>${toggle}</td>
