            const trAttr = perms.canEdit ? `draggable="true" ondragstart="handleDragStart(event, '${m.id}', 'root')" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event, '${m.id}', 'root', 'webpage')"` : '';

