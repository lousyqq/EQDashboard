    // --- 7B. 選單配置管理 (Tree Table) 結合委派權限 (隱藏無權限項目) ---
    function renderMenuConfigTable() {
        const menus = getCustomMenus();
        const tableBody = document.getElementById('menuConfigTableBody');
        if(!tableBody) return;
        tableBody.innerHTML = ''; 

        // 1. 嚴格過濾出使用者有權限「檢視」的所有節點
        const viewableMenus = menus.filter(m => getMenuPermissions(m.id, m.createdBy).canView);

        // 2. 找出 UI 上的「根節點」：本身沒有 parentId，或是他的 parentId 已經不在 viewableMenus 中 (表示是授權的起點)
        let viewableRoots = viewableMenus.filter(m => !m.parentId || !viewableMenus.some(p => p.id === m.parentId));
        
        viewableMenus.sort((a,b) => (a.order || 0) - (b.order || 0));
        viewableRoots.sort((a,b) => (a.order || 0) - (b.order || 0));

        viewableRoots.forEach(root => {
            const rootHtml = generateMenuConfigRow(root, 0, viewableMenus.some(m => m.parentId === root.id), root.id, '');
            if (rootHtml) tableBody.innerHTML += rootHtml;
            
            const level1 = viewableMenus.filter(m => m.parentId === root.id);
            level1.forEach(l1 => {
                const l1Html = generateMenuConfigRow(l1, 1, viewableMenus.some(m => m.parentId === l1.id), l1.id, root.id);
                if (l1Html) tableBody.innerHTML += l1Html;
                
                const level2 = viewableMenus.filter(m => m.parentId === l1.id);
                level2.forEach(l2 => {
                    const l2Html = generateMenuConfigRow(l2, 2, false, l2.id, l1.id, root.id);
                    if (l2Html) tableBody.innerHTML += l2Html;
                });
            });
        });
    }

    function generateMenuConfigRow(menu, level, hasChildren, selfId, parentId, grandParentId = '') {
        const perms = getMenuPermissions(menu.id, menu.createdBy);
        // 保險起見再次檢查，無權限則不渲染
        if (!perms.canView) return '';

        const pad = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5 ms-3' : 'ps-3');
        const isExpanded = expandedSysMenuIds.has(menu.id);
        
        const toggleIcon = hasChildren ?
            `<span ${noDrag}><button type="button" onclick="toggleSysMenuRow('${menu.id}')" class="chevron-btn text-secondary me-2"><i class="fas fa-chevron-${isExpanded ? 'down' : 'right'}"></i></button></span>` :
            `<span class="chevron-btn text-muted me-2" style="cursor: default; opacity: 0.3;"><i class="fas fa-minus"></i></span>`;
            
        const toggle = perms.canEdit ? `<div class="form-check form-switch d-inline-block ms-3 mb-0" ${noDrag}><input class="form-check-input cursor-pointer" type="checkbox" onchange="toggleMenuEnable('${menu.id}', this.checked)" ${menu.enabled !== false ? 'checked' : ''}></div>` : `<span class="badge bg-light text-muted border ms-3">鎖定</span>`;
        
        let isVisible = true;
        if (level === 1 && !expandedSysMenuIds.has(parentId)) isVisible = false;
        if (level === 2 && (!expandedSysMenuIds.has(parentId) || !expandedSysMenuIds.has(grandParentId))) isVisible = false;

        const trAttr = perms.canEdit ? `draggable="true" ondragstart="handleDragStart(event, '${menu.id}', '${menu.parentId || ''}')" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event, '${menu.id}', '${menu.parentId || ''}', 'system')"` : '';

        const actionBtns = perms.canEdit ? `
            <button class="btn btn-sm btn-outline-primary" onclick="editMenuNode('${menu.id}')"><i class="fas fa-edit"></i> 修改</button>
            <button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteMenuNode('${menu.id}')"><i class="fas fa-trash-alt"></i></button>
        ` : `<span class="badge bg-light text-muted border">僅檢視</span>`;

        const typeMap = { 'folder': '📁 選單群組', 'app_grid': '🔗 App集合', 'link': '🔗 看板網頁' };
        const typeText = typeMap[menu.menuMode || 'link'];
        const badgeClass = menu.menuMode === 'folder' ? 'bg-secondary' : 'bg-primary bg-opacity-75';

        return `<tr style="${isVisible ? '' : 'display: none;'}" ${trAttr} class="${perms.canEdit?'draggable-row':''}">
            <td class="${pad}"><div class="fw-bold d-flex align-items-center">${toggleIcon} <span class="text-dark">${menu.name}</span></div></td>
            <td><div class="fw-bold text-primary d-flex align-items-center">${menu.displayName} ${toggle}</div></td>
            <td><span class="badge badge-sub">${level===0?'主選單':(level===1?'子選單':'次子選單')}</span></td>
            <td><span class="badge ${badgeClass} text-white">${typeText}</span></td>
            <td><span class="badge bg-secondary opacity-75">${menu.createdBy || 'admin'}</span></td>
            <td class="text-center" ${noDrag}>${actionBtns}</td>
        </tr>`;
    }

