    }
    
    function handleRoleDragOver(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        return false;
    }
    
    function handleRoleDrop(e) {
        e.preventDefault();
        e.stopPropagation();
        const dropTarget = e.target.closest('.role-menu-item');
        if (draggedRoleItem && dropTarget && draggedRoleItem !== dropTarget) {
            const container = document.getElementById('roleMenuCheckboxes');
            const allItems = Array.from(container.children);
            const draggedIdx = allItems.indexOf(draggedRoleItem);
            const targetIdx = allItems.indexOf(dropTarget);
            if (draggedIdx < targetIdx) {
                dropTarget.after(draggedRoleItem);
            } else {
                dropTarget.before(draggedRoleItem);
            }
        }
        return false;
    }
    
    function handleRoleDragEnd(e) {
        if (draggedRoleItem) draggedRoleItem.classList.remove('dragging');
        draggedRoleItem = null;
    }

