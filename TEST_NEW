    let pendingPerSets = null; // 個人專屬的編輯緩存，仍保留給個人頁面用
    
    // 取消互動元素上的拖曳干擾
    const noDrag = `onmouseenter="this.closest('tr').setAttribute('draggable', false)" onmouseleave="this.closest('tr').setAttribute('draggable', true)"`;

    // 取得包含子父層級的所有關聯看板 ID
    function getAllowedIdsWithHierarchy(menus, initialIds) {
        let ids = new Set(initialIds);
        let size = 0;
        while(ids.size > size) {
            size = ids.size;
            menus.forEach(m => {
                if (m.parentId && ids.has(m.parentId)) ids.add(m.id);
            });
        }
        let finalIds = new Set(ids);
        ids.forEach(id => {
            let m = menus.find(x => x.id === id);
            while(m && m.parentId) { finalIds.add(m.parentId); m = menus.find(x => x.id === m.parentId); }
        });
        return finalIds;
    }

    // 全螢幕收縮顯示/隱藏功能
    function toggleFullscreen() {
