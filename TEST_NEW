    function doLogin() {
        const empIdEl = document.getElementById('empId');
        if (!empIdEl) return;
        const empId = empIdEl.value.trim().toLowerCase();
        const acc = getAccounts().find(a => a.empId.toLowerCase() === empId);

        if (acc) {
            currentUser = { 
                id: acc.empId, 
                name: acc.name, 
                roleLevel: acc.roleLevel || 'user', 
                assignedRoles: acc.assignedRoles || [],
                manageableMenus: acc.manageableMenus || [],
                canEditOthers: acc.canEditOthers || false
            };
            localStorage.setItem('umc_current_user', JSON.stringify(currentUser));
            const overlay = document.getElementById('login-overlay');
            if (overlay) { overlay.style.opacity = '0'; setTimeout(() => { overlay.style.display = 'none'; }, 500); }
            initDashboardUI();
        } else {
            customAlert("找不到此帳號，請確認工號！");
        }
    }
    
    function logout() { 
        localStorage.removeItem('umc_current_user'); 
        currentUser = null;
        
        const overlay = document.getElementById('login-overlay');
        if (overlay) {
            overlay.style.display = 'flex';
            overlay.style.opacity = '1';
        }
        
        const pwdInput = document.getElementById('empPwd');
        if (pwdInput) pwdInput.value = '123456';
    }

