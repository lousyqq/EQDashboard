            }); 
        }
        localStorage.setItem('umc_accounts_v31', JSON.stringify(accounts)); 
        if(modals.acc) modals.acc.hide(); 
        renderAccountTable();

        // 若編輯的是自己，重整權限
        if (currentUser.id === id) {
            doLogin();
        }
    }
    
    function deleteAccount(empId) { if (empId === 'admin') { customAlert("無法刪除最高管理者 admin 帳號！"); return; } customConfirm("確定要刪除此帳號嗎？", function() { let accounts = getAccounts().filter(a => a.empId !== empId); localStorage.setItem('umc_accounts_v31', JSON.stringify(accounts)); renderAccountTable(); }); }

    // --- 11. 需求申請與審核管理 (Apply & Audit) ---
    function renderApplyTable() {
        const tbody = document.getElementById('applyTableBody');
        if (!tbody) return;
        tbody.innerHTML = '';
        
        const reqs = getRequests().filter(r => r.empId === currentUser.id).sort((a,b) => b.timestamp - a.timestamp);
        
        if (reqs.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">目前沒有任何申請紀錄。</td></tr>`;
            return;
        }

        const statusMap = {
            'unreplied': '<span class="badge bg-secondary">尚未回覆</span>',
            'processing': '<span class="badge bg-primary">處理中</span>',
            'pending': '<span class="badge bg-warning text-dark">Pending</span>',
            'rejected': '<span class="badge bg-danger">拒絕</span>',
            'resolved': '<span class="badge bg-success">已處理</span>',
            'withdrawn': '<span class="badge bg-dark">已撤回</span>'
        };

        reqs.forEach(r => {
            const dateStr = new Date(r.timestamp).toLocaleString();
            const replyMsg = r.reply ? r.reply : '<span class="text-muted">-</span>';
            
            let actionBtns = '';
            if (r.status === 'withdrawn') {
                actionBtns = `
                    <button class="btn btn-sm btn-outline-primary me-1" onclick="openApplyModal('${r.id}')"><i class="fas fa-edit"></i> 重新編輯</button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteApplyItem('${r.id}')"><i class="fas fa-trash"></i> 刪除</button>
                `;
            } else if (r.status !== 'resolved' && r.status !== 'rejected') {
                actionBtns = `<button class="btn btn-sm btn-outline-warning" onclick="openWithdrawModal('${r.id}')"><i class="fas fa-undo"></i> 撤回</button>`;
            }

            let wdInfo = r.status === 'withdrawn' ? `<br><small class="text-danger mt-1 d-block"><i class="fas fa-info-circle"></i> 撤回原因: ${r.withdrawReason}</small>` : '';

            tbody.innerHTML += `<tr>
                <td class="small text-muted">${dateStr}</td>
                <td>${r.reason}${wdInfo}</td>
                <td>${statusMap[r.status]}</td>
                <td>${replyMsg}</td>
                <td class="text-center">${actionBtns}</td>
            </tr>`;
        });
    }

    function openApplyModal(id = null) {
        const reasonInput = document.getElementById('applyReason');
        const idInput = document.getElementById('applyReqId');
        if (id) {
            const req = getRequests().find(r => r.id === id);
            if (req) {
                reasonInput.value = req.reason;
                idInput.value = req.id;
            }
        } else {
            reasonInput.value = '';
            idInput.value = '';
        }
        if (modals.apply) modals.apply.show();
    }

    function submitApplyItem(e) {
        e.preventDefault();
        const id = document.getElementById('applyReqId').value;
        const reason = document.getElementById('applyReason').value.trim();
        if (!reason) return;

        let reqs = getRequests();
        if (id) {
            let idx = reqs.findIndex(r => r.id === id);
            if (idx > -1) {
                reqs[idx].reason = reason;
                reqs[idx].status = 'unreplied';
                reqs[idx].timestamp = Date.now();
                reqs[idx].withdrawReason = ''; 
            }
        } else {
            reqs.push({
                id: 'req_' + Date.now(),
                empId: currentUser.id,
                empName: currentUser.name,
                reason: reason,
                timestamp: Date.now(),
                status: 'unreplied',
                reply: ''
            });
        }
        saveRequests(reqs);

        if (modals.apply) modals.apply.hide();
        renderApplyTable();
        customAlert(id ? '需求申請已重新送出！' : '您的需求申請已成功送出！');
    }

    function openWithdrawModal(id) {
        document.getElementById('withdrawReqId').value = id;
        document.getElementById('withdrawReason').value = '';
        if (modals.withdraw) modals.withdraw.show();
    }

    function submitWithdrawItem(e) {
        e.preventDefault();
        const id = document.getElementById('withdrawReqId').value;
        const reason = document.getElementById('withdrawReason').value.trim();
        if (!reason) return;

        let reqs = getRequests();
        let idx = reqs.findIndex(r => r.id === id);
        if (idx > -1) {
            reqs[idx].status = 'withdrawn';
            reqs[idx].withdrawReason = reason;
            saveRequests(reqs);
        }

        if (modals.withdraw) modals.withdraw.hide();
        renderApplyTable();
    }

    function deleteApplyItem(id) {
        customConfirm('確定要刪除這筆已撤回的申請紀錄嗎？', function() {
            let reqs = getRequests().filter(r => r.id !== id);
            saveRequests(reqs);
            renderApplyTable();
        });
    }

    function renderAuditTable() {
        const tbody = document.getElementById('auditTableBody');
        if (!tbody) return;
        tbody.innerHTML = '';
        
        const reqs = getRequests().sort((a,b) => b.timestamp - a.timestamp);
        
        if (reqs.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">目前沒有任何使用者的申請紀錄。</td></tr>`;
            return;
        }

        const statusMap = {
            'unreplied': '<span class="badge bg-secondary">尚未回覆</span>',
            'processing': '<span class="badge bg-primary">處理中</span>',
            'pending': '<span class="badge bg-warning text-dark">Pending</span>',
            'rejected': '<span class="badge bg-danger">拒絕</span>',
            'resolved': '<span class="badge bg-success">已處理</span>',
            'withdrawn': '<span class="badge bg-dark">已撤回</span>'
        };

        reqs.forEach(r => {
            const dateStr = new Date(r.timestamp).toLocaleString();
            let wdInfo = r.status === 'withdrawn' ? `<br><small class="text-danger mt-1 d-block"><i class="fas fa-info-circle"></i> 撤回原因: ${r.withdrawReason}</small>` : '';
            
            tbody.innerHTML += `<tr>
                <td class="fw-bold">${r.empName} <br><small class="text-muted fw-normal">${r.empId}</small></td>
                <td class="small text-muted">${dateStr}</td>
                <td style="max-width: 300px;" class="text-truncate" title="${r.reason}">${r.reason}${wdInfo}</td>
                <td>${statusMap[r.status]}</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary" onclick="openAuditModal('${r.id}')"><i class="fas fa-reply"></i> 回覆審核</button>
                </td>
            </tr>`;
        });
    }

    function openAuditModal(id) {
        const r = getRequests().find(x => x.id === id);
        if (!r) return;

        document.getElementById('auditReqId').value = r.id;
        document.getElementById('auditApplicant').value = `${r.empName} (${r.empId})`;
        document.getElementById('auditReason').value = r.reason;
        document.getElementById('auditStatus').value = r.status;
        document.getElementById('auditReply').value = r.reply || '';

        if (modals.audit) modals.audit.show();
    }

    function saveAuditItem(e) {
        e.preventDefault();
        const id = document.getElementById('auditReqId').value;
        const status = document.getElementById('auditStatus').value;
        const reply = document.getElementById('auditReply').value.trim();

        let reqs = getRequests();
        let idx = reqs.findIndex(x => x.id === id);
        if (idx > -1) {
            reqs[idx].status = status;
            reqs[idx].reply = reply;
            saveRequests(reqs);
        }

        if (modals.audit) modals.audit.hide();
        renderAuditTable();
    }

    // --- 12. 應用程式集合 (App Grid) ---
    function openAppGridPage(menuId, title, element) { navTo('page-app-grid', element, title); document.getElementById('app-grid-title').innerText = title; currentAppGridMenuId = menuId; renderAppGrid(); }
    function renderAppGrid() {
        const container = document.getElementById('app-grid-container'); if(!container) return;
        const apps = getAppItems().filter(a => a.menuId === currentAppGridMenuId); let html = '';
        apps.forEach(app => { const iconSrc = app.iconBase64 || 'https://placehold.co/100x100/e9ecef/495057?text=Web'; html += `<div class="app-card"><div class="app-actions"><button class="app-btn-action app-btn-edit" onclick="editAppItem('${app.id}', event)"><i class="fas fa-edit"></i></button><button class="app-btn-action app-btn-delete" onclick="deleteAppItem('${app.id}', event)"><i class="fas fa-trash"></i></button></div><div class="app-icon-box" onclick="window.open('${app.url}', '${app.target || '_blank'}')"><img src="${iconSrc}" class="app-icon-img" onerror="this.src='https://placehold.co/100x100/e9ecef/495057?text=Error'"></div><div class="app-name" onclick="window.open('${app.url}', '${app.target || '_blank'}')">${app.name}</div></div>`; });
        if (currentUser.roleLevel === 'admin') { html += `<div class="app-card app-add" onclick="openAddAppModal()"><div class="app-icon-box app-add-box"><i class="fas fa-plus"></i></div><div class="app-name text-muted">新增網頁</div></div>`; }
        container.innerHTML = html;
    }
    function openAddAppModal() { 
        document.getElementById('appForm').reset(); 
        document.getElementById('appIdInput').value = ''; 
        const defIcon = 'https://placehold.co/100x100/e9ecef/495057?text=Web';
        document.getElementById('appIconPreview').src = defIcon; 
        document.getElementById('appIconPreview').style.display = 'inline-block'; 
        if(modals.appGrid) modals.appGrid.show(); 
    }
    function editAppItem(appId, e) { e.stopPropagation(); const app = getAppItems().find(a => a.id === appId); if(!app) return; document.getElementById('appIdInput').value = app.id; document.getElementById('appName').value = app.name; document.getElementById('appUrl').value = app.url; if(app.iconBase64) { document.getElementById('appIconPreview').src = app.iconBase64; document.getElementById('appIconPreview').style.display = 'inline-block'; } else { document.getElementById('appIconPreview').style.display = 'none'; } if(modals.appGrid) modals.appGrid.show(); }
    function handleAppIconUpload(e) { const file = e.target.files[0]; if(file) { const reader = new FileReader(); reader.onload = function(evt) { document.getElementById('appIconPreview').src = evt.target.result; document.getElementById('appIconPreview').style.display = 'inline-block'; }; reader.readAsDataURL(file); } }
    function saveAppItem(e) { 
        e.preventDefault(); 
        const id = document.getElementById('appIdInput').value; 
        const name = document.getElementById('appName').value; 
        const url = document.getElementById('appUrl').value; 
        const iconBase64 = document.getElementById('appIconPreview').src; 
        let apps = getAppItems(); 
        if(id) { 
            const idx = apps.findIndex(a => a.id === id); 
            if(idx > -1) { 
                apps[idx].name = name; 
                apps[idx].url = url; 
                if (iconBase64 && iconBase64.startsWith('data:')) { apps[idx].iconBase64 = iconBase64; } 
            } 
        } else { 
            apps.push({ id: 'app_' + Date.now(), menuId: currentAppGridMenuId, name: name, url: url, iconBase64: iconBase64, target: '_blank' }); 
        } 
        saveAppItems(apps); 
        if(modals.appGrid) modals.appGrid.hide(); 
        renderAppGrid(); 
    }
    function deleteAppItem(appId, e) { e.stopPropagation(); customConfirm('確定要刪除此網頁嗎？', function() { let apps = getAppItems().filter(a => a.id !== appId); saveAppItems(apps); renderAppGrid(); }); }

    // --- 13. EAS & 其他共用邏輯 ---
    function renderEasBoard() {
        const now = new Date(); const timeEl = document.getElementById('eas-time'); if(timeEl) timeEl.innerText = now.toLocaleString();
        const container = document.getElementById('eas-grid-container'); if(!container) return; container.innerHTML = '';
        const prefixPool = ['M23', 'YUKA', 'TOKYO', 'SAPP', 'OSAK'];
        const eqData = [ { area: '12M-D1', sec: 'SEC_01', prefix: prefixPool.slice(0,2) }, { area: '12M-D2', sec: 'SEC_02', prefix: prefixPool.slice(2,4) }, { area: '12M-ET', sec: 'SEC_ET', prefix: prefixPool.slice(4,5) } ];
        const statusClasses = ['st-run', 'st-run', 'st-run', 'st-down', 'st-pm', 'st-idle'];
        let htmlStr = '';
        eqData.forEach(row => {
            htmlStr += `<div class="eas-row"><div class="eas-col-area">${row.area}</div><div class="eas-col-sec">${row.sec}</div><div class="eas-col-items">`;
            row.prefix.forEach(prefix => {
                let chamberCount = Math.floor(Math.random() * 5) + 5;
                for(let i=1; i<=chamberCount; i++) {
                    let sClass = statusClasses[Math.floor(Math.random() * statusClasses.length)];
                    let cNum = i < 10 ? '0'+i : i;
                    htmlStr += `<span class="eq-badge ${sClass}">${prefix}/C${cNum}</span>`;
                }
            });
            htmlStr += `</div></div>`;
        });
        container.innerHTML = htmlStr;
    }

    function navTo(pageId, element, subTitle = '') {
        document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
        if(element) element.classList.add('active');
        document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
        const targetPage = document.getElementById(pageId);
        if(targetPage) targetPage.classList.add('active');
        
        pendingPerSets = null;
        const perActions = document.getElementById('per-reorder-actions');
        if(perActions) perActions.style.display = 'none';

        if(pageId === 'page-personal-manage') renderPersonalMenuManage();
        if(pageId === 'page-webpage-manage') renderWebpageTable();
        if(pageId === 'page-menu-manage') renderMenuConfigTable();
        if(pageId === 'page-apply') renderApplyTable();
        if(pageId === 'page-audit-manage') renderAuditTable();
        
        if (pageId === 'page-ze-content') { 
            const titleEl = document.getElementById('ze-sub-title');
            const descEl = document.getElementById('ze-sub-desc');
            if(titleEl) titleEl.innerText = subTitle; 
            if(descEl) descEl.innerText = subTitle; 
        }
    }

    function openDynamicIframe(url, title, element, isFullscreen = false) { 
        if (!url) return; navTo('page-iframe', element);
        const iframeTitle = document.getElementById('iframe-title');
        if(iframeTitle) iframeTitle.innerHTML = `<i class="fas fa-globe me-2"></i>${title}`;
        const iframe = document.getElementById('main-iframe');
        if(iframe) iframe.src = url;
        
        if (isFullscreen) {
            document.body.classList.add('fullscreen-mode');
        } else {
            document.body.classList.remove('fullscreen-mode');
        }
    }

    function customAlert(msg) { const alertMsg = document.getElementById('systemAlertMsg'); if(alertMsg) alertMsg.innerHTML = msg; if(systemAlertModalObj) systemAlertModalObj.show(); }
    function customConfirm(msg, cb) { const confirmMsg = document.getElementById('systemConfirmMsg'); if(confirmMsg) confirmMsg.innerHTML = msg; confirmActionCallback = cb; if(systemConfirmModalObj) systemConfirmModalObj.show(); }
    
    // Bind Confirm Button action
    document.addEventListener('DOMContentLoaded', function() {
        const confirmBtn = document.getElementById('systemConfirmBtn');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', function() {
                if (confirmActionCallback && typeof confirmActionCallback === 'function') {
                    confirmActionCallback();
                }
                if (systemConfirmModalObj) systemConfirmModalObj.hide();
            });
        }
    });
</script>
