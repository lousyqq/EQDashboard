    // --- 4. 動態側邊欄渲染 ---
    function renderSidebarMenus() {
        if (!currentUser) return;
        const currentFabObj = getFabs().find(f => f.fabName === currentFab);
        if (!currentFabObj) return;

        let menus = JSON.parse(JSON.stringify(getCustomMenus()));
        let pSets = currentLayoutMode === 'personal' ? getPersonalSettings(currentUser.id) : {};

        const fabRoleIds = currentFabObj.assignedRoles || [];
        const userRoleIds = currentUser.assignedRoles || [];

        const activeRoleIds = (currentUser.roleLevel === 'admin')
            ? fabRoleIds
            : fabRoleIds.filter(id => userRoleIds.includes(id));

        const roles = getRoles();
        let initialMenuIds = [];
        activeRoleIds.forEach(roleId => {
            const role = roles.find(r => r.id === roleId);
            if (role && role.allowedMenuIds) {
                role.allowedMenuIds.forEach(mId => {
                    if (!initialMenuIds.includes(mId)) initialMenuIds.push(mId);
                });
            }
        });

        let allowedIds = getAllowedIdsWithHierarchy(menus, initialMenuIds);

        if (currentLayoutMode === 'personal') {
            menus.forEach(m => {
                if(pSets[m.id]) {
                    if(pSets[m.id].hidden !== undefined) m.enabled = !pSets[m.id].hidden;
                    if(pSets[m.id].target !== undefined) m.target = pSets[m.id].target;
                    if(pSets[m.id].icon !== undefined) m.icon = pSets[m.id].icon;
                    if(pSets[m.id].order !== undefined) m.order = pSets[m.id].order;
                }
            });
        }

        // 過濾已啟用並包含在權限內的節點
        menus = menus.filter(m => m.enabled !== false && allowedIds.has(m.id));

        // 將左方選單的顯示順序
        menus.sort((a, b) => {
            if (currentLayoutMode === 'system' && !a.parentId && !b.parentId) {
                let idxA = initialMenuIds.indexOf(a.id);
                let idxB = initialMenuIds.indexOf(b.id);
                if (idxA !== -1 || idxB !== -1) {
                    return (idxA === -1 ? 9999 : idxA) - (idxB === -1 ? 9999 : idxB);
                }
            }
            return (a.order || 0) - (b.order || 0);
        });

        const rootMenus = menus.filter(m => !m.parentId);
        
        let html = '';
        rootMenus.forEach(root => html += generateSidebarMenuItem(root, menus, 0));
        
        const container = document.getElementById('dynamic-sidebar-menus');
        if(container) container.innerHTML = html;
    }

    function generateSidebarMenuItem(menu, allMenus, level) {
        const children = allMenus.filter(m => m.parentId === menu.id);
        const hasChildren = children.length > 0;
        const padClass = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5 ms-2' : '');
        let iconHtml = menu.icon ? `<i class="${menu.icon} fa-fw me-3"></i>` : `<i class="fas ${hasChildren?'fa-folder text-warning':'fa-chevron-right text-muted'} fa-fw me-3"></i>`;
        
        let actionAttr = '';
        if (hasChildren) actionAttr = `data-bs-toggle="collapse" data-bs-target="#collapse-${menu.id}"`;
        else if (menu.menuMode === 'app_grid') actionAttr = `onclick="openAppGridPage('${menu.id}', '${menu.displayName}', this)"`;
        else if (menu.menuMode === 'folder') actionAttr = ''; // 純名稱群組若無子節點則無反應
        else if (menu.url) {
            if (menu.target === 'blank') actionAttr = `onclick="window.open('${menu.url}')"`;
            else if (menu.target === 'fullscreen') actionAttr = `onclick="openDynamicIframe('${menu.url}', '${menu.displayName}', this, true)"`;
            else actionAttr = `onclick="openDynamicIframe('${menu.url}', '${menu.displayName}', this, false)"`;
        }
        else if (menu.targetPage) actionAttr = `onclick="navTo('${menu.targetPage}', this, '${menu.displayName}')"`;

        let dName = (i18n[currentLang] && i18n[currentLang]['dyn_' + menu.id]) ? i18n[currentLang]['dyn_' + menu.id] : menu.displayName;

        if (hasChildren) {
            let html = `<div class="menu-item ${padClass}" ${actionAttr}>${iconHtml}<span>${dName}</span><i class="fas fa-chevron-down ms-auto dropdown-icon" style="font-size:0.8rem;"></i></div><div class="collapse" id="collapse-${menu.id}"><div class="py-1">`;
            children.forEach(child => html += generateSidebarMenuItem(child, allMenus, level + 1));
            html += `</div></div>`;
            return html;
        } else {
            return `<div class="menu-item ${padClass}" ${actionAttr}>${iconHtml}<span>${dName}</span></div>`;
        }
    }

    // --- 5. 拖曳排序邏輯 (原生 HTML5 Drag & Drop) ---
    function handleDragStart(e, id, parentId) {
        if (e.target.closest('button') || e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') {
            e.preventDefault();
            return;
        }
        dragSrcEl = e.target.closest('tr');
        if(!dragSrcEl) return;
        dragSrcId = id;
        dragSrcParentId = parentId;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', id);
        setTimeout(() => { if (dragSrcEl) dragSrcEl.classList.add('dragging'); }, 0);
    }

    function handleDragOver(e) {
        if (e.preventDefault) { e.preventDefault(); }
        e.dataTransfer.dropEffect = 'move';
        const tr = e.target.closest('tr');
        if (tr && tr !== dragSrcEl && tr.classList.contains('draggable-row')) {
            tr.classList.add('drag-over');
        }
        return false;
    }

    function handleDragLeave(e) {
        const tr = e.target.closest('tr');
        if (tr) tr.classList.remove('drag-over');
    }

    function handleDrop(e, targetId, targetParentId, mode) {
        if (e.stopPropagation) { e.stopPropagation(); }
        const tr = e.target.closest('tr');
        if (tr) tr.classList.remove('drag-over');
        if (dragSrcEl) dragSrcEl.classList.remove('dragging');

        if (dragSrcId === targetId) return false;
        
        if (mode === 'system') {
            if (dragSrcParentId !== targetParentId) { customAlert('只能在同一層級（相同的父選單）內拖曳排序！'); return false; }
            reorderSystemMenu(dragSrcId, targetId, targetParentId);
        } else if (mode === 'personal') {
            if (dragSrcParentId !== targetParentId) { customAlert('只能在同一層級（相同的父選單）內拖曳排序！'); return false; }
            reorderPersonalMenu(dragSrcId, targetId, targetParentId);
        } else if (mode === 'webpage') {
            reorderWebpageMenu(dragSrcId, targetId);
        }
        return false;
    }

    function reorderSystemMenu(srcId, targetId, parentId) {
        let menus = getCustomMenus();
        let siblings = menus.filter(m => (m.parentId || '') === parentId);
        siblings.sort((a,b) => (a.order || 0) - (b.order || 0));
        
        const srcIdx = siblings.findIndex(m => m.id === srcId);
        const targetIdx = siblings.findIndex(m => m.id === targetId);
        
        if (srcIdx > -1 && targetIdx > -1) {
            const [movedItem] = siblings.splice(srcIdx, 1);
            siblings.splice(targetIdx, 0, movedItem);
            
            siblings.forEach((s, idx) => {
                const realMenu = menus.find(x => x.id === s.id);
                if (realMenu) realMenu.order = idx * 10;
            });
            
            localStorage.setItem('umc_custom_menus_v31', JSON.stringify(menus));
            renderMenuConfigTable(); 
            renderSidebarMenus(); 
        }
    }

    function reorderWebpageMenu(srcId, targetId) {
        let menus = getCustomMenus();
        const srcIdx = menus.findIndex(m => m.id === srcId);
        const targetIdx = menus.findIndex(m => m.id === targetId);
        
        if (srcIdx > -1 && targetIdx > -1) {
            const [movedItem] = menus.splice(srcIdx, 1);
            menus.splice(targetIdx, 0, movedItem);
            
            menus.forEach((m, idx) => m.order = idx * 10);
            
            localStorage.setItem('umc_custom_menus_v31', JSON.stringify(menus));
            renderWebpageTable(); 
            renderMenuConfigTable(); 
            renderSidebarMenus(); 
        }
    }

    function reorderPersonalMenu(srcId, targetId, parentId) {
        if (!pendingPerSets) pendingPerSets = JSON.parse(JSON.stringify(getPersonalSettings(currentUser.id)));
        let menus = getCustomMenus();
        
        let siblings = menus.filter(m => (m.parentId || '') === parentId);
        siblings.forEach(s => { s.tempOrder = pendingPerSets[s.id]?.order ?? 999; });
        siblings.sort((a,b) => a.tempOrder - b.tempOrder);

        const srcIdx = siblings.findIndex(m => m.id === srcId);
        const targetIdx = siblings.findIndex(m => m.id === targetId);
        
        if (srcIdx > -1 && targetIdx > -1) {
            const [movedItem] = siblings.splice(srcIdx, 1);
            siblings.splice(targetIdx, 0, movedItem);
            
            siblings.forEach((m, idx) => {
                if(!pendingPerSets[m.id]) pendingPerSets[m.id] = {};
                pendingPerSets[m.id].order = idx * 10;
            });
            
            document.getElementById('per-reorder-actions').style.display = 'flex';
            renderPersonalMenuManage();
        }
    }

    // --- 6. 個人選單管理 (完全隔離於各使用者) ---
    function renderPersonalMenuManage() {
        const tbody = document.getElementById('personalMenuTableBody');
        if(!tbody) return;
        tbody.innerHTML = '';
        
        const currentFabObj = getFabs().find(f => f.fabName === currentFab);
        if (!currentFabObj) return;

        const roles = getRoles();
        const menusData = getCustomMenus();
        
        const fabRoleIds = currentFabObj.assignedRoles || [];
        const userRoleIds = currentUser.assignedRoles || [];

        const activeRoleIds = (currentUser.roleLevel === 'admin')
            ? fabRoleIds
            : fabRoleIds.filter(id => userRoleIds.includes(id));

        let initialMenuIds = [];
        activeRoleIds.forEach(roleId => {
            const role = roles.find(r => r.id === roleId);
            if (role && role.allowedMenuIds) initialMenuIds.push(...role.allowedMenuIds);
        });

        let allowedIds = getAllowedIdsWithHierarchy(menusData, initialMenuIds);
        let menus = JSON.parse(JSON.stringify(menusData)).filter(m => allowedIds.has(m.id));
        let pSets = pendingPerSets || getPersonalSettings(currentUser.id);
        
        // 個人化排序優先
        menus.forEach(m => { m.order = pSets[m.id]?.order ?? (m.order || 999); });
        menus.sort((a,b) => a.order - b.order);

        menus.forEach(m => {
            if(!expandedPerMenuIds.has(m.id) && isPerAllExpanded) expandedPerMenuIds.add(m.id);
        });

        const renderRow = (menu, path, level, parentId = '', grandParentId = '') => {
            const isHidden = pSets[menu.id] ? pSets[menu.id].hidden : false;
            const currentTarget = pSets[menu.id] ? (pSets[menu.id].target || menu.target || 'iframe') : (menu.target || 'iframe');
            const currentIcon = pSets[menu.id] ? (pSets[menu.id].icon || menu.icon || 'fas fa-desktop') : (menu.icon || 'fas fa-desktop');
            const pad = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5 ms-3' : 'ps-3');
            
            const children = menus.filter(m => m.parentId === menu.id);
            const hasChildren = children.length > 0;
            const isExpanded = expandedPerMenuIds.has(menu.id);

            const toggleIcon = hasChildren ?
                `<span ${noDrag}><button type="button" onclick="togglePerMenuRow('${menu.id}')" class="chevron-btn text-secondary me-2"><i class="fas fa-chevron-${isExpanded ? 'down' : 'right'}"></i></button></span>` :
                `<span class="chevron-btn text-muted me-2" style="cursor: default; opacity: 0.3;"><i class="fas fa-minus"></i></span>`;

            let isVisible = true;
            if (level === 1 && !expandedPerMenuIds.has(parentId)) isVisible = false;
            if (level === 2 && (!expandedPerMenuIds.has(parentId) || !expandedPerMenuIds.has(grandParentId))) isVisible = false;

            const iconHtml = `<i class="${currentIcon} me-2 ${isHidden?'text-muted':'text-primary'} fs-5"></i>`;
            const toggle = `<div class="form-check form-switch d-inline-block ms-3 mb-0" ${noDrag}><input class="form-check-input cursor-pointer" type="checkbox" onchange="togglePersonalProp('${menu.id}', 'hidden', !this.checked)" ${!isHidden ? 'checked' : ''} title="顯示/隱藏"></div>`;

            let configHtml = '';
            if (!hasChildren) {
                configHtml = currentTarget === 'blank' ? '<span class="text-info small fw-bold">另開新分頁</span>' : (currentTarget === 'fullscreen' ? '<span class="text-success small fw-bold">全螢幕</span>' : '<span class="text-info small fw-bold">畫面內嵌</span>');
            } else {
                configHtml = '-';
            }

            const trAttr = `draggable="true" ondragstart="handleDragStart(event, '${menu.id}', '${parentId || ''}')" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event, '${menu.id}', '${parentId || ''}', 'personal')"`;

            let rowHtml = `<tr style="${isVisible ? '' : 'display: none;'}" ${trAttr} class="draggable-row ${isHidden?'opacity-75':''}">
                <td class="${pad}"><div class="fw-bold d-flex align-items-center">${toggleIcon} ${iconHtml} <span class="${isHidden?'text-decoration-line-through text-muted':''}">${menu.displayName}</span> ${toggle}</div></td>
                <td><span class="badge badge-sub">${level===0?'主選單':(level===1?'子選單':'次子選單')}</span></td>
                <td>${configHtml}</td>
                <td class="text-center" ${noDrag}>
                    <button class="btn btn-sm btn-outline-primary" onclick="editPersonalMenu('${menu.id}')"><i class="fas fa-edit"></i> 編輯</button>
                </td>
            </tr>`;
            tbody.innerHTML += rowHtml;

            children.forEach(child => renderRow(child, child.displayName, level + 1, menu.id, parentId));
        };

        menus.filter(m => !m.parentId).forEach(root => renderRow(root, root.displayName, 0));
    }

    function togglePerMenuRow(menuId) {
        if (expandedPerMenuIds.has(menuId)) expandedPerMenuIds.delete(menuId);
        else expandedPerMenuIds.add(menuId);
        renderPersonalMenuManage();
    }

    function togglePerAllMenus() {
        const menusData = getCustomMenus();
        const menusWithChildren = menusData.filter(m => menusData.some(child => child.parentId === m.id));

        if (isPerAllExpanded) {
            expandedPerMenuIds.clear();
            isPerAllExpanded = false;
            const btn = document.getElementById('btn-per-toggle-all');
            if(btn) btn.innerHTML = '<i class="fas fa-expand-arrows-alt me-1"></i> 全部展開';
        } else {
            menusWithChildren.forEach(m => expandedPerMenuIds.add(m.id));
            isPerAllExpanded = true;
            const btn = document.getElementById('btn-per-toggle-all');
            if(btn) btn.innerHTML = '<i class="fas fa-compress-arrows-alt me-1"></i> 全部收合';
