                html += `
                    <li class="mb-2">
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input acc-manage-menu-check cursor-pointer mt-0 me-2 border-secondary shadow-sm" type="checkbox" value="${m.id}" id="chk_am_${m.id}" ${isChecked} onchange="handleManageMenuCheck(this, '${m.id}')">
                            <label class="form-check-label cursor-pointer fw-bold text-dark d-flex align-items-center" for="chk_am_${m.id}">
                                <i class="${icon} me-2 fs-6"></i> ${m.displayName}
                                <span class="badge bg-secondary bg-opacity-10 text-muted ms-2 fw-normal border" style="font-size: 0.7rem;">${m.name}</span>
                            </label>
                        </div>
                        ${buildTree(m.id)}
                    </li>
                `;
            });
            html += `</ul>`;
            return html;
        }

        const treeHtml = buildTree(null);
        el.innerHTML = treeHtml || '<div class="text-muted small py-2 text-center">尚無任何選單可供委派</div>';
    }

    // 新增：處理委派目錄勾選時的上下層連動邏輯
    function handleManageMenuCheck(checkbox, menuId) {
        const isChecked = checkbox.checked;
        const menus = getCustomMenus();
        
        // 1. 向下連動：勾選/取消所有子目錄與看板
        function getDescendants(parentId) {
            let descendants = [];
            const children = menus.filter(m => m.parentId === parentId);
            children.forEach(child => {
                descendants.push(child.id);
                descendants = descendants.concat(getDescendants(child.id));
            });
            return descendants;
        }
        
        const allDescendantIds = getDescendants(menuId);
        allDescendantIds.forEach(id => {
            const childCb = document.getElementById('chk_am_' + id);
            if (childCb) childCb.checked = isChecked;
        });

        // 2. 向上連動：若「取消勾選」，則所有的父目錄也必須自動取消勾選
        // (因為只要父目錄被勾選，系統就會默認底下所有子節點皆具有權限)
        if (!isChecked) {
            let currentId = menuId;
            while (currentId) {
                const m = menus.find(x => x.id === currentId);
                if (m && m.parentId) {
                    const parentCb = document.getElementById('chk_am_' + m.parentId);
                    if (parentCb) parentCb.checked = false;
                    currentId = m.parentId;
                } else {
                    currentId = null;
                }
            }
        }
    }
    
