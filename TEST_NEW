    // --- 修改核心：權限檢查 (分離檢視、編輯、新增子層權限) ---
    function getMenuPermissions(nodeId, nodeCreatedBy) {
        let perms = { canView: false, canEdit: false, canAddChild: false };
        if (!currentUser) return perms;
        if (currentUser.roleLevel === 'admin') return { canView: true, canEdit: true, canAddChild: true };

        const isMyOwn = (nodeCreatedBy === currentUser.id);
        const isDelegated = currentUser.manageableMenus && currentUser.manageableMenus.includes(nodeId);
        
        let isUnderDelegated = false;
        const menus = getCustomMenus();
        const node = menus.find(x => x.id === nodeId);
        let currentId = node ? node.parentId : null;
        
        while (currentId) {
            if (currentUser.manageableMenus && currentUser.manageableMenus.includes(currentId)) {
                isUnderDelegated = true;
                break;
            }
            const m = menus.find(x => x.id === currentId);
            currentId = m ? m.parentId : null;
        }

        // Edit logic: 可以編輯的前提是「自己建立的」或是「在委派範圍內且允許修改他人內容」
        if (isMyOwn) {
            perms.canEdit = true;
        } else if (isUnderDelegated && currentUser.canEditOthers) {
            perms.canEdit = true;
        } else if (isDelegated && currentUser.canEditOthers) {
            // 如果是直接委派的目錄，且允許修改他人內容，也可以編輯
            perms.canEdit = true;
        }

        // Add Child logic: 是否可以在此目錄下新增子選單
        // 自己能編輯的目錄，或是被委派的目錄(即使不是自己建的)，都可以向下新增子層
        if (perms.canEdit || isDelegated || isUnderDelegated) {
            perms.canAddChild = true;
        }

        // View logic: 是否顯示在畫面上
        if (perms.canAddChild || perms.canEdit) {
            perms.canView = true;
        } else {
            // 若本身無編輯也無法新增，檢查是否為「被委派目錄的祖先」，需顯示以維持樹狀結構(展開用)
            let isAncestor = false;
            if (currentUser.manageableMenus) {
                for (let mId of currentUser.manageableMenus) {
                    let cId = mId;
                    while (cId) {
                        if (cId === nodeId) { isAncestor = true; break; }
                        const cm = menus.find(x => x.id === cId);
                        cId = cm ? cm.parentId : null;
                    }
                    if (isAncestor) break;
                }
            }
            if (isAncestor) {
                perms.canView = true;
            }
        }

        return perms;
    }

