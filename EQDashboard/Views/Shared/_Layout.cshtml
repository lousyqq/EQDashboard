<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EQ Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root { --primary-bg: #002b5e; }
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow-x: hidden; }
        #wrapper { display: flex; width: 100%; height: 100vh; overflow: hidden; }
        #sidebar { width: 260px; background: #fff; border-right: 1px solid #e0e0e0; display: flex; flex-direction: column; z-index: 1000; }
        #content-wrapper { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .top-navbar { background-color: var(--primary-bg); color: white; padding: 10px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); display: flex; justify-content: space-between; align-items: center; z-index: 1001;}

        .menu-item { padding: 12px 20px; color: #495057; text-decoration: none; display: flex; align-items: center; border-left: 4px solid transparent; transition: all 0.2s; }
        .menu-item:hover { background-color: #f8f9fa; color: var(--primary-bg); }
        .menu-item.active { background-color: #e9ecef; color: var(--primary-bg); border-left-color: var(--primary-bg); font-weight: bold; }
        .menu-item.locked { color: #adb5bd; cursor: pointer; }
        .menu-item.locked:hover { background-color: #fff3cd; color: #856404; }
        .menu-section { padding: 15px 20px 5px; font-size: 0.8rem; font-weight: bold; color: #adb5bd; text-transform: uppercase; }

        main { padding: 20px; overflow-y: auto; flex: 1; }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- 左側邊欄 -->
        <div id="sidebar">
            <div class="p-3 border-bottom d-flex align-items-center justify-content-center bg-light">
                <h5 class="m-0 fw-bold" style="color: var(--primary-bg);">UMC <span class="fw-light">Dashboard</span></h5>
            </div>
            <div class="flex-grow-1 overflow-auto py-2">
                <div class="menu-section">個人工作區</div>
                <a href="@Url.Action("Index", "Dashboard")" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-home fa-fw me-2"></i> 首頁總覽
                </a>

                <div class="menu-section mt-2">系統看板 (需權限)</div>

                <!-- 核心 RBAC 邏輯：判斷登入者是否為 Admin -->
                @if (User.IsInRole("Admin"))
                {
                    <a href="@Url.Action("FdcIndex", "Dashboard")" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "FdcIndex" ? "active" : "")">
                        <i class="fas fa-table fa-fw me-2"></i> FDC 指標看板
                    </a>
                }
                else
                {
                    <!-- 一般 User 顯示上鎖按鈕，觸發申請視窗 -->
                    <a href="#" class="menu-item locked" onclick="showAuthModal()">
                        <i class="fas fa-table fa-fw me-2"></i> FDC 指標看板
                        <i class="fas fa-lock ms-auto text-warning"></i>
                    </a>
                }

                <div class="menu-section mt-2">系統設定</div>
                <a href="@Url.Action("ApplyAccess", "Dashboard")" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "ApplyAccess" ? "active" : "")">
                    <i class="fas fa-key fa-fw me-2"></i> 權限申請中心
                </a>
            </div>
        </div>

        <!-- 右側內容區 -->
        <div id="content-wrapper">
            <!-- 頂部導覽列 -->
            <div class="top-navbar">
                <div class="d-flex align-items-center">
                    <span class="fs-5 fw-bold">@ViewData["Title"]</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <!-- 語系切換 (前端示範版) -->
                    <select class="form-select form-select-sm w-auto bg-light border-0">
                        <option value="zh">繁體中文</option>
                        <option value="en">English</option>
                        <option value="ja">日本語</option>
                    </select>

                    <div class="dropdown">
                        <div class="d-flex align-items-center text-white cursor-pointer" data-bs-toggle="dropdown" style="cursor:pointer;">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; color: var(--primary-bg);">
                                <i class="fas fa-user"></i>
                            </div>
                            <div>
                                <div class="fs-7 fw-bold lh-1">@User.Identity.Name</div>
                                <small class="text-white-50 fs-8">Role: @(User.IsInRole("Admin") ? "Admin" : "Basic")</small>
                            </div>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i> 登出</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 動態子頁面載入位置 -->
            <main id="main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- 權限不足提示 Modal -->
    <div class="modal fade" id="authModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning text-dark border-0">
                    <h5 class="modal-title fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> 權限不足</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="fas fa-lock text-muted mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
                    <p class="fs-6">您目前的帳號沒有瀏覽此模組報表的權限。<br>是否要立即前往「權限申請中心」提交申請？</p>
                </div>
                <div class="modal-footer border-0 justify-content-center bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <a href="@Url.Action("ApplyAccess", "Dashboard")" class="btn btn-primary">前往申請</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showAuthModal() {
            var modal = new bootstrap.Modal(document.getElementById('authModal'));
            modal.show();
        }
    </script>
</body>
</html>