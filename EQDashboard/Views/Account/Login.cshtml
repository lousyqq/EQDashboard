@{
    Layout = null; // 登入頁面不需要左側選單與導覽列
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 - EQ Dashboard</title>
    <!-- 修正：乾淨的 CSS 連結 -->
    <link href="[https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css](https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css)" rel="stylesheet">
    <link href="[https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css](https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css)" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #002b5e;
        }

        body {
            background: linear-gradient(135deg, var(--primary-bg), #00509e);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-box {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 400px;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h3 class="text-center mb-4" style="color: var(--primary-bg); font-weight: bold;">
            <i class="fas fa-microchip me-2"></i>EQ Dashboard
        </h3>

        <div class="text-center mb-3">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-secondary" onclick="changeLoginLang('zh')">中</button>
                <button type="button" class="btn btn-outline-secondary" onclick="changeLoginLang('en')">EN</button>
                <button type="button" class="btn btn-outline-secondary" onclick="changeLoginLang('ja')">日</button>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 fs-7">@ViewBag.Error</div>
        }

        <div class="alert alert-info py-2 fs-7 mb-4">
            <small><i class="fas fa-info-circle me-1"></i> <span id="hint-text">測試帳號：<br>輸入 <b>admin</b> 取得完整權限<br>輸入 <b>user</b> 取得一般權限</span></small>
        </div>

        <!-- 這裡將表單 Post 給 AccountController 的 Login Action -->
        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold" id="lbl-id">工號 (Employee ID)</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fas fa-id-badge"></i></span>
                    <input type="text" name="empId" class="form-control" placeholder="admin / user" required>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label text-muted small fw-bold" id="lbl-pwd">密碼 (Password)</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fas fa-lock"></i></span>
                    <input type="password" name="empPwd" class="form-control" value="123456" required>
                </div>
            </div>
            <button type="submit" class="btn w-100 py-2 fw-bold text-white" style="background-color: var(--primary-bg);">
                <i class="fas fa-sign-in-alt me-2"></i><span id="btn-text">登 入 Login</span>
            </button>
        </form>
    </div>

    <script>
        const loginI18n = {
            zh: { id: "工號 (Employee ID)", pwd: "密碼 (Password)", btn: "登 入 Login", hint: "測試帳號：<br>輸入 <b>admin</b> 取得完整權限<br>輸入 <b>user</b> 取得一般權限" },
            en: { id: "Employee ID", pwd: "Password", btn: "Login", hint: "Test: <b>admin</b> (Full) / <b>user</b> (Basic)" },
            ja: { id: "社員番号", pwd: "パスワード", btn: "ログイン", hint: "テスト：<b>admin</b> (全権限) / <b>user</b> (基本)" }
        };
        function changeLoginLang(lang) {
            document.getElementById('lbl-id').innerText = loginI18n[lang].id;
            document.getElementById('lbl-pwd').innerText = loginI18n[lang].pwd;
            document.getElementById('btn-text').innerText = loginI18n[lang].btn;
            document.getElementById('hint-text').innerHTML = loginI18n[lang].hint;
            localStorage.setItem('eq_dashboard_lang', lang);
        }
        document.addEventListener("DOMContentLoaded", () => {
            const savedLang = localStorage.getItem('eq_dashboard_lang') || 'zh';
            changeLoginLang(savedLang);
        });
    </script>
</body>
</html>