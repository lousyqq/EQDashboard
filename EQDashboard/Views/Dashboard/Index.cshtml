            const dept = document.getElementById('accDept').value.trim();
            const canManage = document.getElementById('accCanManage').checked;

            const assignedRoles = Array.from(document.querySelectorAll('.acc-role-check:checked')).map(cb => cb.value);

            let accounts = getAccounts();

            if (editModeId) {
                const idx = accounts.findIndex(a => a.empId === editModeId);
                if (idx > -1) {
                    accounts[idx].name = name;
                    accounts[idx].department = dept;
                    accounts[idx].canManage = canManage;
                    accounts[idx].role = canManage ? 'System Admin' : 'Basic User';
                    accounts[idx].assignedRoles = assignedRoles;
                }
            } else {
                if (accounts.some(a => a.empId === empId)) {
                    customAlert("此工號已存在！");
                    return;
                }
                accounts.push({
                    empId: empId,
                    name: name,
                    department: dept,
                    role: canManage ? 'System Admin' : 'Basic User',
                    canManage: canManage,
                    assignedRoles: assignedRoles
                });
            }

            localStorage.setItem('umc_accounts_v4', JSON.stringify(accounts));
            if (accModal) accModal.hide();
            renderAccountTable();

            // 若正在修改目前登入的自己，更新當前選單視圖
            if (currentUser && currentUser.id === editModeId) {
                currentUser.name = name;
                currentUser.isAdmin = canManage;
                currentUser.assignedRoles = assignedRoles;
                document.getElementById('user-name').innerText = name;
                renderSidebarMenus();
            }
        }

        function deleteAccount(empId) {
            if (empId === 'admin') { customAlert("無法刪除預設的 admin 帳號！"); return; }
            customConfirm("確定要刪除此帳號嗎？", function() {
                let accounts = getAccounts().filter(a => a.empId !== empId);
                localStorage.setItem('umc_accounts_v4', JSON.stringify(accounts));
                renderAccountTable();
            });
        }


        // --- 10. App Grid 與 Iframe 顯示邏輯 ---
        function openDynamicIframe(url, title, element) {
            if (!url) return;
            navTo('page-iframe', element);
            document.getElementById('iframe-title').innerHTML = `<i class="fas fa-globe me-2"></i>${title}`;
            document.getElementById('main-iframe').src = url;
            document.getElementById('iframe-popout-btn').onclick = () => window.open(url, '_blank');
        }

        let currentAppMenuId = null;
        let currentAppIconBase64 = null;
        const defaultAppIcon = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64"><rect width="64" height="64" rx="14" fill="%23002b5e"/><text x="32" y="38" font-family="Arial" font-weight="bold" font-size="20" fill="white" text-anchor="middle">APP</text></svg>';

        function openAppGridPage(menuId, menuName, element) {
            navTo('page-app-grid', element);
            document.getElementById('app-grid-title').innerText = menuName;
            currentAppMenuId = menuId;
            renderAppGridList();
        }

        function renderAppGridList() {
            const container = document.getElementById('app-grid-container');
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v2')) || [];
            apps = apps.filter(a => a.menuId === currentAppMenuId);

            let html = '';
            apps.forEach(app => {
                html += `
                <div class="app-card">
                    ${currentUser && currentUser.isAdmin ? `
                    <div class="app-actions">
                        <button class="app-btn-action app-btn-edit" onclick="editAppItem('${app.id}')" title="編輯"><i class="fas fa-pen"></i></button>
                        <button class="app-btn-action app-btn-delete" onclick="deleteAppItem('${app.id}')" title="刪除"><i class="fas fa-times"></i></button>
                    </div>` : ''}
                    <div class="app-icon-box" onclick="window.open('${app.url}', '_blank')">
                        <img src="${app.icon || defaultAppIcon}" class="app-icon-img">
                    </div>
                    <div class="app-name" onclick="window.open('${app.url}', '_blank')">${app.name}</div>
                </div>`;
            });

            if (currentUser && currentUser.isAdmin) {
                html += `
                <div class="app-card app-add" onclick="openAddAppModal()">
                    <div class="app-icon-box app-add-box">
                        <i class="fas fa-plus"></i>
                    </div>
                    <div class="app-name text-muted">新增網頁</div>
                </div>`;
            }
            container.innerHTML = html;
        }

        function openAddAppModal() {
            document.getElementById('appForm').reset();
            document.getElementById('appIdInput').value = '';
            document.getElementById('appIconPreview').style.display = 'none';
            currentAppIconBase64 = null;
            document.querySelector('#appGridModal .modal-title').innerHTML = '<i class="fas fa-plus-square me-2"></i>新增 APP 網頁';
            if(appGridModal) appGridModal.show();
        }

        function editAppItem(appId) {
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v2')) || [];
            let app = apps.find(a => a.id === appId);
            if(!app) return;

            document.getElementById('appForm').reset();
            document.getElementById('appIdInput').value = app.id;
            document.getElementById('appName').value = app.name;
            document.getElementById('appUrl').value = app.url;

            currentAppIconBase64 = app.icon === defaultAppIcon ? null : app.icon;

            const preview = document.getElementById('appIconPreview');
            if(app.icon && app.icon !== defaultAppIcon) {
                preview.src = app.icon;
                preview.style.display = 'inline-block';
            } else {
                preview.style.display = 'none';
                preview.src = '';
            }

            document.querySelector('#appGridModal .modal-title').innerHTML = '<i class="fas fa-edit me-2"></i>編輯 APP 網頁';
            if(appGridModal) appGridModal.show();
        }

        function handleAppIconUpload(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    currentAppIconBase64 = e.target.result;
                    const preview = document.getElementById('appIconPreview');
                    preview.src = currentAppIconBase64;
                    preview.style.display = 'inline-block';
                }
                reader.readAsDataURL(file);
            }
        }

        function saveAppItem(event) {
            event.preventDefault();
            const id = document.getElementById('appIdInput').value;
            const name = document.getElementById('appName').value.trim();
            const url = document.getElementById('appUrl').value.trim();

            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v2')) || [];

            if (id) {
                const index = apps.findIndex(a => a.id === id);
                if (index > -1) {
                    apps[index].name = name;
                    apps[index].url = url;
                    apps[index].icon = currentAppIconBase64 || defaultAppIcon;
                }
            } else {
                apps.push({
                    id: 'app_' + Date.now(),
                    menuId: currentAppMenuId,
                    name: name,
                    url: url,
                    icon: currentAppIconBase64 || defaultAppIcon
                });
            }

            localStorage.setItem('umc_custom_apps_v2', JSON.stringify(apps));
            if(appGridModal) appGridModal.hide();
            renderAppGridList();
        }

        function deleteAppItem(appId) {
            customConfirm('確定要移除此 APP 捷徑嗎？', function() {
                let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v2')) || [];
                apps = apps.filter(a => a.id !== appId);
                localStorage.setItem('umc_custom_apps_v2', JSON.stringify(apps));
                renderAppGridList();
            });
        }

        // --- 11. EAS 模擬資料 ---
        function renderEasBoard() {
            const now = new Date();
            document.getElementById('eas-time').innerText = now.toLocaleString();
            const container = document.getElementById('eas-grid-container');
            container.innerHTML = '';
            const prefixPool = ['M23', 'YUKA', 'TOKYO', 'SAPP', 'OSAK'];
            const eqData = [
                { area: '12M-D1', sec: 'SEC_01', prefix: prefixPool.slice(0,2) },
                { area: '12M-D2', sec: 'SEC_02', prefix: prefixPool.slice(2,4) },
                { area: '12M-ET', sec: 'SEC_ET', prefix: prefixPool.slice(4,5) }
            ];
            const statusClasses = ['st-run', 'st-run', 'st-run', 'st-down', 'st-pm', 'st-idle'];
            let htmlStr = '';

            eqData.forEach(row => {
                htmlStr += `<div class="eas-row"><div class="eas-col-area">${row.area}</div><div class="eas-col-sec">${row.sec}</div><div class="eas-col-items">`;
                row.prefix.forEach(prefix => {
                    let chamberCount = Math.floor(Math.random() * 5) + 5;
                    for(let i=1; i<=chamberCount; i++) {
                        let sClass = statusClasses[Math.floor(Math.random() * statusClasses.length)];
                        let cNum = i < 10 ? '0'+i : i;
                        htmlStr += `<span class="eq-badge ${sClass}" title="${prefix}/C${cNum}">${prefix}/C${cNum}</span>`;
                    }
                });
                htmlStr += `</div></div>`;
            });
            container.innerHTML = htmlStr;
        }

    </script>
}