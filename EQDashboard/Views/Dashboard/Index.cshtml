        // 宣告全域變數
        let currentUser = null;
        let appGridModal = null;
        let menuModal = null;
        let roleModal = null;
        let accModal = null;
        let fabModal = null;
        let systemAlertModalObj = null;
        let systemConfirmModalObj = null;
        let confirmActionCallback = null;

        // 確保 DOM 元素載入後再初始化
        document.addEventListener('DOMContentLoaded', function() {
            // 從 LocalStorage 抓取登入狀態
            const storedUser = localStorage.getItem('umc_current_user');
            if (storedUser) {
                currentUser = JSON.parse(storedUser);
                document.getElementById('login-overlay').style.display = 'none';
            }

            if (typeof bootstrap !== 'undefined') {
                appGridModal = new bootstrap.Modal(document.getElementById('appGridModal'));
                menuModal = new bootstrap.Modal(document.getElementById('menuModal'));
                roleModal = new bootstrap.Modal(document.getElementById('roleModal'));
                accModal = new bootstrap.Modal(document.getElementById('accModal'));
                fabModal = new bootstrap.Modal(document.getElementById('fabModal'));

                systemAlertModalObj = new bootstrap.Modal(document.getElementById('systemAlertModal'));
                systemConfirmModalObj = new bootstrap.Modal(document.getElementById('systemConfirmModal'));

                document.getElementById('systemConfirmBtn').addEventListener('click', function() {
                    if (confirmActionCallback) confirmActionCallback();
                    systemConfirmModalObj.hide();
                });
            }

            // 強制初始化所有資料表為最新版本
            getCustomMenus();
            getRoles();
            getFabs();
            getAccounts();

            if (currentUser) {
                initDashboardUI();
            }

            // 綁定登入輸入框的 Enter 事件 (修復 Null 報錯，並在 DOM 載入後綁定)
            document.getElementById('empPwd')?.addEventListener('keypress', function (e) { if (e.key === 'Enter') doLogin(); });
            document.getElementById('empId')?.addEventListener('keypress', function (e) { if (e.key === 'Enter') doLogin(); });
        });

        // 系統啟動初始化介面
        function initDashboardUI() {
            if (!currentUser) return;

            document.getElementById('user-name').innerText = currentUser.name;
            document.getElementById('user-role').innerText = currentUser.role;
            document.getElementById('dash-role-display').innerText = currentUser.isAdmin ? "系統管理員 (編輯權限)" : "一般使用者 (唯讀)";
            if(currentUser.isAdmin) {
                document.getElementById('dash-role-display').className = "mt-3 mb-1 text-danger";
            } else {
                document.getElementById('dash-role-display').className = "mt-3 mb-1 text-dark";
            }

            const countKey = 'eq_login_count_' + currentUser.id;
            document.getElementById('user-login-count').innerText = localStorage.getItem(countKey) || '1';
            document.getElementById('login-count-container').style.display = 'block';

            const manageDash = document.getElementById('menu-manage-dash');
            const manageFab = document.getElementById('menu-fab-manage');
            const manageRole = document.getElementById('menu-role-manage');
            const manageAcc = document.getElementById('menu-account-manage');

            if (currentUser.isAdmin) {
                manageDash.style.display = 'block'; manageDash.classList.remove('locked');
                manageFab.style.display = 'block'; manageFab.classList.remove('locked');
                manageRole.style.display = 'block'; manageRole.classList.remove('locked');
                manageAcc.style.display = 'block'; manageAcc.classList.remove('locked');
            }

            const fabs = getFabs();
            switchFab(fabs.length > 0 ? fabs[0].fabName : '12A');

            if(currentUser.isAdmin) {
                renderCustomMenus();
                renderFabTable();
                renderRoleTable();
                renderAccountTable();
            }

            renderFabSwitcher();
            renderSidebarMenus();
            changeLanguage('zh');
        }

        function customAlert(msg) {
            document.getElementById('systemAlertMsg').innerHTML = msg;
            if(systemAlertModalObj) systemAlertModalObj.show();
        }

        function customConfirm(msg, callback) {
            document.getElementById('systemConfirmMsg').innerHTML = msg;
            confirmActionCallback = callback;
            if(systemConfirmModalObj) systemConfirmModalObj.show();
        }

        // --- 2. 資料庫層初始化 (Accounts, Roles, Menus, Fabs) ---
        function getFabs() {
            let fabsStr = localStorage.getItem('umc_fabs_v2');
            if (!fabsStr) {
                const defaultFabs = [
                    { id: 'fab_12a', displayName: '12A', fabName: '12A', defaultLang: 'zh', assignedRoles: ['role_1'] },
                    { id: 'fab_12m', displayName: '12M', fabName: '12M', defaultLang: 'ja', assignedRoles: ['role_2'] },
                    { id: 'fab_12i', displayName: '12i', fabName: '12i', defaultLang: 'en', assignedRoles: ['role_3'] }
                ];
                localStorage.setItem('umc_fabs_v2', JSON.stringify(defaultFabs));
                return defaultFabs;
            }
            return JSON.parse(fabsStr);
        }

        function getRoles() {
            let rolesStr = localStorage.getItem('umc_roles_v5');
            if (!rolesStr) {
                const defaultRoles = [
                    { id: 'role_1', groupName: '12A 完整模組', allowedMenuIds: ['menu_eas_main', 'menu_eqas', 'menu_daily', 'menu_ze', 'menu_fdc'] },
                    { id: 'role_2', groupName: '12M 專用模組', allowedMenuIds: ['menu_eas_12m'] },
                    { id: 'role_3', groupName: '12i 專用模組', allowedMenuIds: ['menu_fdc'] }
                ];
                localStorage.setItem('umc_roles_v5', JSON.stringify(defaultRoles));
                return defaultRoles;
            }
            return JSON.parse(rolesStr);
        }

        function getAccounts() {
            let accStr = localStorage.getItem('umc_accounts_v4');
            if (!accStr) {
                const allRoles = getRoles().map(r => r.id);
                const defaultAccs = [
                    { empId: 'admin', name: '系統管理員', department: '資訊處', role: 'System Admin', canManage: true, assignedRoles: allRoles },
                    { empId: 'user', name: '一般使用者', department: '製造部', role: 'Basic User', canManage: false, assignedRoles: ['role_1', 'role_2'] }
                ];
                localStorage.setItem('umc_accounts_v4', JSON.stringify(defaultAccs));
                return defaultAccs;
            }
            return JSON.parse(accStr);
        }

        function getCustomMenus() {
            let menusStr = localStorage.getItem('umc_custom_menus_v9');
            if (!menusStr) {
                const defaultMenus = [
                    { id: 'menu_eas_main', name: 'EAS', displayName: 'EAS', targetPage: 'page-eas-main', icon: 'fas fa-desktop', reqAuth: true, parentId: null, enabled: true, description: 'EAS 系統主入口' },
                    { id: 'menu_eqas', name: 'EQAS', displayName: 'EQAS', targetPage: 'page-eqas', icon: 'fas fa-chart-bar', reqAuth: true, parentId: null, enabled: true, description: 'EQAS 報表' },
                    { id: 'menu_daily', name: '日管', displayName: '日管', targetPage: 'page-daily', icon: 'fas fa-calendar-check', reqAuth: true, parentId: null, enabled: true, description: '日常管理模組' },
                    { id: 'menu_ze', name: 'ZE 強化防禦', displayName: 'ZE 強化防禦', icon: 'fas fa-shield-alt', reqAuth: true, parentId: null, enabled: true, description: 'ZE 專案防禦設定' },
                    { id: 'menu_ze_mnop', name: 'MNOP', displayName: 'MNOP', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze', enabled: true },
