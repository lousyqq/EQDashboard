            }
            return JSON.parse(menusStr);
        }

        // --- 3. 側邊欄渲染 (結合群組權限與自訂排序) ---
        function generateSidebarMenuItem(menu, allMenus, level) {
            const children = allMenus.filter(m => m.parentId === menu.id && m.enabled !== false);
            const hasChildren = children.length > 0;

            let defaultIcon = '';
            if (level === 0) defaultIcon = hasChildren ? 'fa-folder text-warning' : 'fa-link text-primary';
            else if (level === 1 && hasChildren) defaultIcon = 'fa-folder-open text-warning';
            else defaultIcon = 'fa-angle-right text-muted';

            const iconHtml = menu.icon ? `<i class="${menu.icon} fa-fw me-2"></i>` : `<i class="fas ${defaultIcon} fa-fw me-2"></i>`;
            const padClass = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5 ms-2' : '');

            const displayTxt = menu.displayName || menu.name;
            const displayNameHTML = menu.i18nKey ? `<span data-i18n="${menu.i18nKey}">${i18n[currentLang][menu.i18nKey] || displayTxt}</span>` : `<span>${displayTxt}</span>`;

            let actionAttr = '';
            if (hasChildren) {
                actionAttr = `data-bs-toggle="collapse" data-bs-target="#collapse-${menu.id}" aria-expanded="false"`;
            } else if (menu.menuMode === 'app_grid') {
                actionAttr = `onclick="openAppGridPage('${menu.id}', '${displayTxt}', this)"`;
            } else if (menu.url) {
                if (menu.target === 'blank') {
                    actionAttr = `onclick="window.open('${menu.url}', '_blank')"`;
                } else if (menu.target === 'popup') {
                    actionAttr = `onclick="window.open('${menu.url}', 'popup_${menu.id}', 'width=1100,height=700,top=100,left=150,toolbar=no,menubar=no,scrollbars=yes,resizable=yes'); return false;"`;
                } else {
                    actionAttr = `onclick="openDynamicIframe('${menu.url}', '${displayTxt}', this)"`;
                }
            } else if (menu.targetPage) {
                actionAttr = `onclick="navTo('${menu.targetPage}', this, '${displayTxt}')"`;
            }

            if (hasChildren) {
                let html = `
                <div class="menu-item ${padClass}" id="menu-el-${menu.id}" ${actionAttr}>
                    ${iconHtml} ${displayNameHTML}
                    <i class="fas fa-chevron-down ms-auto dropdown-icon" style="font-size: 0.8rem;"></i>
                </div>
                <div class="collapse" id="collapse-${menu.id}">
                    <div class="bg-light py-1 ${level === 0 ? 'border-bottom' : ''}">
                `;
                children.forEach(child => html += generateSidebarMenuItem(child, allMenus, level + 1));
                html += `</div></div>`;
                return html;
            } else {
                return `<div class="menu-item ${padClass}" id="menu-el-${menu.id}" ${actionAttr}>${iconHtml} ${displayNameHTML}</div>`;
            }
        }

        function renderSidebarMenus() {
            if (!currentUser) {
                document.getElementById('dynamic-sidebar-menus').innerHTML = '';
                return;
            }

            const currentFabObj = getFabs().find(f => f.fabName === currentFab);
            let activeRoles = [];
            if (currentFabObj && currentFabObj.assignedRoles) {
                activeRoles = getRoles().filter(r => currentFabObj.assignedRoles.includes(r.id));
            }

            if (currentUser.assignedRoles && currentUser.assignedRoles.length > 0) {
                activeRoles = activeRoles.filter(r => currentUser.assignedRoles.includes(r.id));
            } else {
                activeRoles = [];
            }

            const allowedRootIds = [];
            activeRoles.forEach(r => {
                r.allowedMenuIds.forEach(id => {
                    if (!allowedRootIds.includes(id)) {
                        allowedRootIds.push(id);
                    }
                });
            });

            const menus = getCustomMenus();
            const rootMenus = [];
            allowedRootIds.forEach(id => {
                const menu = menus.find(m => m.id === id && !m.parentId && m.enabled !== false);
                if (menu) {
                    rootMenus.push(menu);
                }
            });

            let html = '';
            rootMenus.forEach(root => html += generateSidebarMenuItem(root, menus, 0));
            document.getElementById('dynamic-sidebar-menus').innerHTML = html;
        }

        // --- 4. 語系與廠區切換 ---
        let currentLang = 'zh';
        let currentFab = '12A';

        function changeLanguage(lang) {
            currentLang = lang;
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18n[lang] && i18n[lang][key]) el.innerHTML = i18n[lang][key];
            });
            const langCodes = { 'zh': 'ZH', 'en': 'EN', 'ja': 'JA' };
            const langCodeEl = document.getElementById('current-lang-code');
            if (langCodeEl) langCodeEl.innerText = langCodes[lang];
            document.querySelectorAll('.lang-check').forEach(el => el.classList.add('d-none'));
            const checkEl = document.getElementById('check-' + lang);
            if (checkEl) checkEl.classList.remove('d-none');
        }

        function renderFabSwitcher() {
            const container = document.getElementById('fab-switcher-container');
            if (!container) return;
            let html = `<span class="text-white-50 small px-2 fw-bold" style="font-size: 0.75rem;" data-i18n="fab_label">廠區</span>`;
            const fabs = getFabs();
            fabs.forEach(f => {
                html += `<button class="fab-btn ${currentFab === f.fabName ? 'active' : ''}" onclick="switchFab('${f.fabName}')">${f.displayName}</button>`;
            });
            container.innerHTML = html;
            changeLanguage(currentLang);
        }

        function switchFab(fabName) {
            currentFab = fabName;
            const fabs = getFabs();
            const fabObj = fabs.find(f => f.fabName === fabName);
            if (fabObj) currentLang = fabObj.defaultLang;

            renderFabSwitcher();
            document.getElementById('dash-fab-display').innerText = fabObj ? fabObj.displayName : fabName;

            if (fabName === '12M') {
                document.querySelector('.eas-table-container').style.borderTopColor = "#dd4b39";
            }

            renderSidebarMenus();
            changeLanguage(currentLang);

            navTo('page-home', document.querySelector('[onclick*="page-home"]'));
            if(currentUser && fabName === '12M') renderEasBoard();
        }

        // --- 5. 登入與登出邏輯 (單頁 SPA) ---
        function doLogin() {
            const empIdInput = document.getElementById('empId').value.trim().toLowerCase();
            const accounts = getAccounts();
            const acc = accounts.find(a => a.empId.toLowerCase() === empIdInput);

            if (acc) {
                currentUser = { id: acc.empId, name: acc.name, role: acc.role, isAdmin: acc.canManage, assignedRoles: acc.assignedRoles || [] };
                localStorage.setItem('umc_current_user', JSON.stringify(currentUser));
            } else {
                customAlert("找不到此帳號，請聯絡管理員確認！"); return;
            }

            const countKey = 'eq_login_count_' + currentUser.id;
            let loginCount = parseInt(localStorage.getItem(countKey) || '0');
            localStorage.setItem(countKey, ++loginCount);

            document.getElementById('login-overlay').style.opacity = '0';
            setTimeout(() => { document.getElementById('login-overlay').style.display = 'none'; }, 500);

            initDashboardUI();
        }

        function logout() {
            localStorage.removeItem('umc_current_user');
            currentUser = null;
            document.getElementById('login-count-container').style.display = 'none';

            document.getElementById('login-overlay').style.display = 'flex';
            setTimeout(() => { document.getElementById('login-overlay').style.opacity = '1'; }, 50);

            const manageDash = document.getElementById('menu-manage-dash');
            const manageFab = document.getElementById('menu-fab-manage');
            const manageRole = document.getElementById('menu-role-manage');
            const manageAcc = document.getElementById('menu-account-manage');

            if (manageDash) { manageDash.style.display = 'none'; manageDash.classList.add('locked'); }
            if (manageFab) { manageFab.style.display = 'none'; manageFab.classList.add('locked'); }
            if (manageRole) { manageRole.style.display = 'none'; manageRole.classList.add('locked'); }
            if (manageAcc) { manageAcc.style.display = 'none'; manageAcc.classList.add('locked'); }

            document.getElementById('main-iframe').src = "";
            renderSidebarMenus();
            navTo('page-home', document.querySelector('[onclick*="page-home"]'));
        }

        function navTo(pageId, element, subTitle = '') {
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            if(element) element.classList.add('active');

            document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');

            if (pageId === 'page-ze-content') {
                document.getElementById('ze-sub-title').innerText = subTitle;
                document.getElementById('ze-sub-desc').innerText = subTitle;
            }
        }

        // --- 6. 系統看板管理 ---
        function toggleMenuMode() {
            const mode = document.querySelector('input[name="menuMode"]:checked').value;
            const urlGroup = document.getElementById('urlGroup');
            const targetGroup = document.getElementById('targetGroup');

            if (mode === 'app_grid') {
                urlGroup.style.display = 'none';
                targetGroup.style.display = 'none';
            } else {
                urlGroup.style.display = 'block';
                targetGroup.style.display = 'block';
            }
        }

        function renderCustomMenus() {
            const menus = getCustomMenus();
            const tableBody = document.getElementById('customMenuTableBody');
            const parentSelect = document.getElementById('customMenuParent');

            tableBody.innerHTML = '';
            parentSelect.innerHTML = '<option value="">無 (作為主選單)</option>';

            const rootMenus = menus.filter(m => !m.parentId);

            rootMenus.forEach(root => {
                const level1 = menus.filter(m => m.parentId === root.id);
                parentSelect.innerHTML += `<option value="${root.id}">${root.name}</option>`;
                tableBody.innerHTML += generateManageTableRow(root, 0, level1.length > 0);

                level1.forEach(l1 => {
                    const level2 = menus.filter(m => m.parentId === l1.id);
                    parentSelect.innerHTML += `<option value="${l1.id}">&nbsp;&nbsp;&nbsp;-- ${l1.name} (子選單)</option>`;
                    tableBody.innerHTML += generateManageTableRow(l1, 1, level2.length > 0);

                    level2.forEach(l2 => {
                        tableBody.innerHTML += generateManageTableRow(l2, 2, false);
                    });
                });
            });
        }

        function generateManageTableRow(menu, level, hasChildren) {
            let padding = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5' : 'ps-3');

            let iconHtml = menu.icon ? `<i class="${menu.icon} me-2 text-primary"></i>` : `<i class="${level === 0 ? (hasChildren ? 'fas fa-folder text-warning' : 'fas fa-link text-primary') : 'fas fa-angle-right text-muted'} me-2"></i>`;
            let levelBadge = level === 0 ? '<span class="badge bg-secondary">主選單</span>' : (level === 1 ? '<span class="badge bg-light text-dark border">子選單</span>' : '<span class="badge bg-light text-muted border">次子選單</span>');

            let isChecked = menu.enabled !== false ? 'checked' : '';
            let statusToggle = `
                <div class="form-check form-switch d-inline-block ms-3 mb-0" style="vertical-align: text-bottom;">
                    <input class="form-check-input" style="cursor: pointer;" type="checkbox" onchange="toggleMenuEnable('${menu.id}', this.checked)" ${isChecked} title="啟用/停用此看板">
                </div>
            `;

            let descHtml = menu.description ? `<div class="text-muted mt-1" style="font-size:0.75rem; white-space:normal; max-width:250px;"><i class="fas fa-info-circle me-1"></i>${menu.description}</div>` : '';

            let urlDisplay = '';
            if (menu.menuMode === 'app_grid') {
                urlDisplay = `<span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2"><i class="fas fa-th-large me-1"></i>App 應用集合</span>`;
            } else {
                let targetBadge = '';
                if (menu.url) {
                    if (menu.target === 'blank') targetBadge = '<span class="badge bg-info ms-1">新分頁</span>';
                    else if (menu.target === 'popup') targetBadge = '<span class="badge bg-warning text-dark ms-1">彈出視窗</span>';
                    else targetBadge = '<span class="badge bg-success ms-1">內嵌</span>';
                }
                urlDisplay = menu.url ? `<a href="${menu.url}" target="_blank">${menu.url}</a> ${targetBadge}` : (menu.targetPage ? `<span class="text-info small"><i class="fas fa-microchip me-1"></i>內部頁面</span>` : '-');
            }

            let displayTxt = menu.displayName || menu.name;

            return `
                <tr>
                    <td class="${padding}">
                        <div class="fw-bold d-flex align-items-center">${iconHtml} ${displayTxt} <span class="text-muted ms-2 fw-normal small">(${menu.name})</span> ${statusToggle}</div>
                        ${descHtml}
                    </td>
                    <td>${levelBadge}</td>
                    <td class="text-muted small">${urlDisplay}</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="editCustomMenu('${menu.id}')"><i class="fas fa-edit"></i></button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteCustomMenu('${menu.id}')"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            `;
