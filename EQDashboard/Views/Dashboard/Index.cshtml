@{
    ViewData["Title"] = "首頁總覽";
}

<div class="alert alert-success border-0 shadow-sm d-flex align-items-center mb-4">
    <i class="fas fa-check-circle fs-3 me-3"></i>
    <div>
        <h5 class="alert-heading mb-1">歡迎登入 EQ Performance Dashboard</h5>
        <p class="mb-0 fs-7">您的基本身分已驗證。若需查看特定廠區或模組的詳細指標報表，請前往「權限申請中心」開通權限。</p>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card h-100 border-start border-4 border-primary border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted fw-bold text-uppercase">我的權限狀態</h6>
                <h3 class="mt-3 mb-1 @(User.IsInRole("Admin") ? "text-success" : "text-warning")">
                    @(User.IsInRole("Admin") ? "System Admin" : "Basic User")
                </h3>
                <small class="text-muted">@(User.IsInRole("Admin") ? "已解鎖所有模組" : "僅具備基本檢視權限")</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-white border-0 shadow-sm" style="background-color: #002b5e;">
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <h5 class="mb-3 letter-spacing-1">企業文化 CULTURE</h5>
                <div class="d-flex justify-content-center gap-3 fs-4 fw-bold mb-1">
                    <span>正</span><span>實</span><span>迅</span><span>慧</span>
                </div>
            </div>
        </div>
    </div>
</div>