        function editCustomMenu(id) {
            const menus = getCustomMenus();
            const menu = menus.find(m => m.id === id);
            if (!menu) return;

            document.getElementById('editMenuId').value = menu.id;
            document.getElementById('customMenuName').value = menu.name;
            document.getElementById('customMenuDisplayName').value = menu.displayName || menu.name;
            document.getElementById('customMenuUrl').value = menu.url || '';
            document.getElementById('customMenuParent').value = menu.parentId || '';
            document.getElementById('customMenuTarget').value = menu.target || 'iframe';
            document.getElementById('customMenuIcon').value = menu.icon || '';
            document.getElementById('customMenuDescription').value = menu.description || '';
            document.getElementById('customMenuEnabled').checked = menu.enabled !== false;

            document.getElementById(menu.menuMode === 'app_grid' ? 'modeAppGrid' : 'modeLink').checked = true;
            toggleMenuMode();

            document.getElementById('menuModalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>編輯看板結構';
            document.getElementById('submitMenuBtn').innerHTML = '<i class="fas fa-save me-1"></i> 更新';

            if (menuModal) menuModal.show();
        }

        function saveCustomMenu(event) {
            event.preventDefault();
            const id = document.getElementById('editMenuId').value;
            const mode = document.querySelector('input[name="menuMode"]:checked').value;
            const name = document.getElementById('customMenuName').value.trim();
            const displayName = document.getElementById('customMenuDisplayName').value.trim();
            const url = document.getElementById('customMenuUrl').value.trim();
            const parentId = document.getElementById('customMenuParent').value;
            const target = document.getElementById('customMenuTarget').value;
            const icon = document.getElementById('customMenuIcon').value;
            const description = document.getElementById('customMenuDescription').value.trim();
            const enabled = document.getElementById('customMenuEnabled').checked;

            if (!name || !displayName) return;

            let menus = getCustomMenus();
            const newId = 'dyn_' + Date.now();

            if (parentId && id) {
                let currentParent = menus.find(m => m.id === parentId);
                while(currentParent) {
                    if (currentParent.id === id) { customAlert("錯誤：不能將看板設定為自己子選單的子選單！"); return; }
                    currentParent = menus.find(m => m.id === currentParent.parentId);
                }
            }

            if (id) {
                const index = menus.findIndex(m => m.id === id);
                if (index > -1) {
                    menus[index].name = name;
                    menus[index].displayName = displayName;
                    menus[index].i18nKey = null;

                    menus[index].menuMode = mode;
                    menus[index].url = mode === 'app_grid' ? '' : url;
                    if (url && mode !== 'app_grid') menus[index].targetPage = null;
                    menus[index].parentId = parentId || null;
                    menus[index].target = target;
                    menus[index].icon = icon;
                    menus[index].description = description;
                    menus[index].enabled = enabled;
                }
            } else {
                menus.push({
                    id: newId,
                    name: name,
                    displayName: displayName,
                    menuMode: mode,
                    url: mode === 'app_grid' ? '' : url,
                    parentId: parentId || null,
                    target: target,
                    icon: icon,
                    description: description,
                    enabled: enabled,
                    reqAuth: true
                });

                if (!parentId && currentUser && currentUser.assignedRoles) {
                    let roles = getRoles();
                    let rolesUpdated = false;
                    roles.forEach(r => {
                        if (currentUser.assignedRoles.includes(r.id)) {
                            if (!r.allowedMenuIds.includes(newId)) {
                                r.allowedMenuIds.push(newId);
                                rolesUpdated = true;
                            }
                        }
                    });
                    if (rolesUpdated) {
                        localStorage.setItem('umc_roles_v4', JSON.stringify(roles));
                    }
                }
            }

            localStorage.setItem('umc_custom_menus_v9', JSON.stringify(menus));

            if (menuModal) menuModal.hide();

            renderCustomMenus();
            if(currentUser.isAdmin) {
                renderRoleTable();
            }
            renderSidebarMenus();
        }

        function toggleMenuEnable(id, isEnabled) {
            let menus = getCustomMenus();
            let index = menus.findIndex(m => m.id === id);
            if (index > -1) {
                menus[index].enabled = isEnabled;
                localStorage.setItem('umc_custom_menus_v9', JSON.stringify(menus));
                renderSidebarMenus();
            }
        }

        function deleteCustomMenu(id) {
            customConfirm('確定要刪除此看板嗎？若有子選單也會一併被遞迴刪除。', function() {
                let menus = getCustomMenus();

                let idsToDelete = new Set([id]);
                let size = 0;
                while(idsToDelete.size > size) {
                    size = idsToDelete.size;
                    menus.forEach(m => {
                        if(idsToDelete.has(m.parentId)) idsToDelete.add(m.id);
                    });
                }

                menus = menus.filter(m => !idsToDelete.has(m.id));
                localStorage.setItem('umc_custom_menus_v9', JSON.stringify(menus));

                let roles = getRoles();
                roles.forEach(r => {
                    r.allowedMenuIds = r.allowedMenuIds.filter(mid => !idsToDelete.has(mid));
                });
                localStorage.setItem('umc_roles_v4', JSON.stringify(roles));

                let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
                apps = apps.filter(a => !idsToDelete.has(a.menuId));
                localStorage.setItem('umc_custom_apps_v1', JSON.stringify(apps));

                renderCustomMenus();
                renderRoleTable();
                renderSidebarMenus();
            });
        }

