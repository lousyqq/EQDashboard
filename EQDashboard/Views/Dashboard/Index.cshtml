                    { id: 'menu_ze_extra', name: 'Extra Sensor', displayName: 'Extra Sensor', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze', enabled: true },
                    { id: 'menu_eas_12m', name: '12M EAS 機況', displayName: '12M EAS 機況', targetPage: 'page-eas', icon: 'fas fa-th', reqAuth: true, parentId: null, enabled: true, description: '12M 專用設備機況看板' },
                    { id: 'menu_fdc', name: 'FDC 指標看板', displayName: 'FDC 指標看板', url: '/Dashboard/FdcIndex', target: 'iframe', menuMode: 'link', icon: 'fas fa-table', reqAuth: true, parentId: null, enabled: true, description: 'FDC 指標監控頁面' }
                ];
                localStorage.setItem('umc_custom_menus_v9', JSON.stringify(defaultMenus));
