        // --- 8. 權限管理 (Roles) 支援膠囊標籤拖曳 ---
        function setupRoleMenuDragAndDrop() {
            const items = document.querySelectorAll('.role-menu-item');
            let draggedItem = null;

            items.forEach(item => {
                item.setAttribute('draggable', true);

                item.addEventListener('dragstart', function(e) {
                    draggedItem = this;
                    setTimeout(() => this.classList.add('opacity-50'), 0);
                });

                item.addEventListener('dragend', function() {
                    setTimeout(() => this.classList.remove('opacity-50'), 0);
                    draggedItem = null;
                });

                item.addEventListener('dragover', function(e) {
                    e.preventDefault();
                });

                item.addEventListener('dragenter', function(e) {
                    e.preventDefault();
                });

                item.addEventListener('drop', function(e) {
                    e.preventDefault();
                    if (draggedItem && this !== draggedItem) {
                        let allItems = Array.from(this.parentNode.children);
                        let draggedIdx = allItems.indexOf(draggedItem);
                        let targetIdx = allItems.indexOf(this);

                        if (draggedIdx < targetIdx) {
                            this.parentNode.insertBefore(draggedItem, this.nextSibling);
                        } else {
                            this.parentNode.insertBefore(draggedItem, this);
                        }
                    }
                });
            });
        }

        function renderRoleManageForm(orderedIds = []) {
            let rootMenus = getCustomMenus().filter(m => !m.parentId);

            if (orderedIds && orderedIds.length > 0) {
                const sortedMenus = [];
                orderedIds.forEach(id => {
                    const m = rootMenus.find(x => x.id === id);
                    if (m) sortedMenus.push(m);
                });
                rootMenus.forEach(m => {
                    if (!orderedIds.includes(m.id)) sortedMenus.push(m);
                });
                rootMenus = sortedMenus;
            }

            const container = document.getElementById('roleMenuCheckboxes');
            let html = '';
            rootMenus.forEach(m => {
                let statusLabel = m.enabled !== false ? '' : '<span class="badge bg-danger ms-1" style="font-size:0.6rem;">停用</span>';
                html += `
                <div class="role-menu-item d-inline-block" draggable="true" title="按住可拖曳排序">
                    <input type="checkbox" class="btn-check role-menu-check" id="chk_role_${m.id}" value="${m.id}" autocomplete="off">
                    <label class="btn btn-outline-primary rounded-pill fw-bold shadow-sm px-3 py-1" for="chk_role_${m.id}" style="border-width: 2px; user-select: none;">
                        ${m.name} ${statusLabel}
