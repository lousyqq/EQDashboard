@{
    ViewData["Title"] = "FDC 指標看板";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive" style="max-height: 60vh;">
            <table class="table table-bordered table-hover text-center align-middle mb-0 text-nowrap">
                <thead class="table-light sticky-top">
                    <tr>
                        <th class="text-start bg-light" style="min-width: 250px; position: sticky; left: 0; z-index: 2;">指標項目 (Index Category)</th>
