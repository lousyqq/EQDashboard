                </thead>
                <tbody>
                    <tr>
                        <td class="text-start fw-bold bg-white" style="position: sticky; left: 0;">1. No Spec Recipe 統計</td>
                        <td><span class="text-primary fw-bold">143</span></td>
                        <td>314</td>
                        <td>229</td>
                        <td>141</td>
                        <td>166</td>
                    </tr>
                    <tr>
                        <td class="text-start fw-bold bg-white" style="position: sticky; left: 0;">3-1. Category 未設 (未開Hold)</td>
                        <td>2</td>
                        <td><span class="badge bg-danger rounded-pill px-2">774</span></td>
                        <td>11</td>
                        <td>42</td>
                        <td>208</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>