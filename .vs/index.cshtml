@{
    ViewData["Title"] = "儀表板總覽";
}

<!-- [頁面] 首頁總覽 -->
<div id="page-home" class="page-section active">
    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center">
        <i class="fas fa-check-circle fs-3 me-3"></i>
        <div>
            <h5 class="alert-heading mb-1" data-i18n="welcome_title">歡迎登入</h5>
            <p class="mb-0 fs-7" data-i18n="welcome_desc">請從左側選單進入各項報表。</p>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card h-100 border-start border-4 border-primary shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase" data-i18n="my_role_title">我的權限狀態</h6>
                    <h3 class="mt-3 mb-1 @(User.IsInRole("Admin") ? "text-success" : "text-warning")" id="dash-role-display">
                        @(User.IsInRole("Admin") ? "System Admin" : "Basic User")
                    </h3>
                    <small class="text-muted" id="dash-role-desc"></small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm" style="border-left: 4px solid #17a2b8;">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase" data-i18n="current_fab_title">目前選擇廠區</h6>
                    <h2 class="mt-3 mb-1 text-info" id="dash-fab-display">12A</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- [頁面] 管理系統看板 (僅 Admin 可見) -->
<div id="page-manage-dash" class="page-section">
    <h4 class="mb-3" data-i18n="manage_dash_title">系統看板管理</h4>
    <div class="alert alert-info py-2">
        <i class="fas fa-info-circle me-2"></i> 您可以在此建立<strong>「連結網址」</strong>或<strong>「應用程式集合 (App Grid)」</strong>。
    </div>
    
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-bold"><i class="fas fa-edit me-2 text-primary"></i>新增 / 編輯看板</div>
        <div class="card-body">
            <form id="menuForm" onsubmit="saveCustomMenu(event)">
                <input type="hidden" id="editMenuId">
                <div class="row g-3">
                    <div class="col-md-12 mb-1 pb-2 border-bottom d-flex flex-wrap gap-4">
                        <div>
                            <label class="form-label fw-bold fs-7 text-muted me-3">看板模式 <span class="text-danger">*</span></label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="menuMode" id="modeLink" value="link" checked onchange="toggleMenuMode()">
                                <label class="form-check-label" for="modeLink"><i class="fas fa-link me-1"></i>連結網址</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="menuMode" id="modeAppGrid" value="app_grid" onchange="toggleMenuMode()">
                                <label class="form-check-label text-primary fw-bold" for="modeAppGrid"><i class="fas fa-th-large me-1"></i>應用集合 (App Grid)</label>
                            </div>
                        </div>
                        <div class="border-start ps-4">
                            <label class="form-label fw-bold fs-7 text-muted me-3">顯示廠區 (可複選) <span class="text-danger">*</span></label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input fab-check" type="checkbox" id="checkFab12A" value="12A" checked>
                                <label class="form-check-label" for="checkFab12A">12A</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input fab-check" type="checkbox" id="checkFab12M" value="12M" checked>
                                <label class="form-check-label" for="checkFab12M">12M</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input fab-check" type="checkbox" id="checkFab12i" value="12i" checked>
                                <label class="form-check-label" for="checkFab12i">12i</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold fs-7 text-muted">看板名稱 <span class="text-danger">*</span></label>
                        <input type="text" id="customMenuName" class="form-control" placeholder="輸入名稱" required>
                    </div>
                    
                    <div class="col-md-3" id="urlGroup">
                        <label class="form-label fw-bold fs-7 text-muted">網址 (URL)</label>
                        <input type="url" id="customMenuUrl" class="form-control" placeholder="https://...">
                    </div>
                    <div class="col-md-2" id="targetGroup">
                        <label class="form-label fw-bold fs-7 text-muted">開啟方式</label>
                        <select id="customMenuTarget" class="form-select">
                            <option value="iframe">嵌入網頁</option>
                            <option value="blank">新分頁</option>
                            <option value="popup">彈出小視窗</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold fs-7 text-muted">所屬父選單</label>
                        <select id="customMenuParent" class="form-select">
                            <!-- 動態載入 -->
                        </select>
                    </div>
                    
                    <div class="col-md-2">
                        <label class="form-label fw-bold fs-7 text-muted">圖示 (Icon)</label>
                        <select id="customMenuIcon" class="form-select">
                            <option value="">預設</option>
                            <option value="fas fa-desktop">🖥️ 電腦/主機</option>
                            <option value="fas fa-chart-bar">📊 長條圖</option>
                            <option value="fas fa-chart-line">📈 趨勢圖</option>
                            <option value="fas fa-chart-pie">🥧 圓餅圖</option>
                            <option value="fas fa-table">📋 表格/數據</option>
                            <option value="fas fa-shield-alt">🛡️ 防禦/安全</option>
                            <option value="fas fa-calendar-check">📅 日期/排程</option>
                            <option value="fas fa-th">🎛️ 面板/模組</option>
                            <option value="fas fa-microchip">🖧 晶片/設備</option>
                            <option value="fas fa-server">🗄️ 伺服器</option>
                            <option value="fas fa-industry">🏭 工廠/廠房</option>
                            <option value="fas fa-database">💽 資料庫</option>
                            <option value="fas fa-cogs">⚙️ 設定/機制</option>
                            <option value="fas fa-clipboard-list">📝 報表/清單</option>
                        </select>
                    </div>
                    
                    <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                        <button type="button" class="btn btn-light" id="cancelMenuBtn" onclick="resetMenuForm()" style="display:none;">取消</button>
                        <button type="submit" class="btn btn-primary" id="submitMenuBtn"><i class="fas fa-plus me-1"></i> 新增看板</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold"><i class="fas fa-list me-2 text-primary"></i>系統看板樹狀結構</div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">名稱</th>
                        <th>層級</th>
                        <th>廠區</th>
                        <th>連結與配置</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody id="customMenuTableBody">
                    <!-- Javascript 動態產生 -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- [頁面] 應用程式集合 (App Grid 顯示區) -->
<div id="page-app-grid" class="page-section">
    <h4 class="mb-3 fw-bold"><i class="fas fa-th-large text-primary me-2"></i><span id="app-grid-title">應用程式集合</span></h4>
    <div class="app-grid" id="app-grid-container">
        <!-- Javascript 動態產生 APP 圖示 -->
    </div>
</div>

<!-- [頁面] 動態 Iframe 內容區 -->
<div id="page-iframe" class="page-section">
    <div class="iframe-header">
        <h5 class="m-0 fw-bold text-primary" id="iframe-title"><i class="fas fa-globe me-2"></i>外部網頁</h5>
        <div>
            <button class="btn btn-sm btn-light me-2" onclick="closeDynamicIframe()"><i class="fas fa-times me-1"></i>關閉</button>
            <button class="btn btn-sm btn-outline-primary" id="iframe-popout-btn"><i class="fas fa-external-link-alt me-1"></i>在新分頁開啟</button>
        </div>
    </div>
    <iframe id="main-iframe" src=""></iframe>
</div>

<!-- 預設靜態板塊佔位 -->
<div id="page-eas-main" class="page-section"><h4 class="mb-3" data-i18n="menu_eas_main">EAS</h4><div class="alert alert-info"><i class="fas fa-tools me-2"></i> <span data-i18n="page_building">頁面內容建置中...</span></div></div>
<div id="page-eqas" class="page-section"><h4 class="mb-3" data-i18n="menu_eqas">EQAS</h4><div class="alert alert-info"><i class="fas fa-tools me-2"></i> <span data-i18n="page_building">頁面內容建置中...</span></div></div>
<div id="page-daily" class="page-section"><h4 class="mb-3" data-i18n="menu_daily">日管</h4><div class="alert alert-info"><i class="fas fa-tools me-2"></i> <span data-i18n="page_building">頁面內容建置中...</span></div></div>
<div id="page-ze-content" class="page-section"><h4 class="mb-3"><span data-i18n="ze_title">ZE 強化防禦看板</span> - <span id="ze-sub-title" class="text-primary"></span></h4><div class="alert alert-info"><i class="fas fa-chart-line me-2"></i> 這是 <strong id="ze-sub-desc"></strong> 的專屬數據報表。(內容建置中)</div></div>

<!-- 12M EAS 機況看板 -->
<div id="page-eas" class="page-section">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <h4 class="mb-1 fw-bold"><span id="eas-title-fab" class="text-primary">12M</span> <span data-i18n="eas_title_sub">EAS 設備機況看板</span></h4>
            <small class="text-muted"><i class="fas fa-clock me-1"></i><span data-i18n="eas_time_label">最後更新時間: </span> <span id="eas-time"></span></small>
        </div>
        <div class="d-flex gap-2">
            <div class="d-flex align-items-center bg-white border rounded px-3 py-1 me-2 shadow-sm">
                <span class="eq-badge st-run me-1"></span> <small class="me-3" data-i18n="leg_run">Running</small>
                <span class="eq-badge st-down me-1"></span> <small class="me-3" data-i18n="leg_down">Alarm</small>
                <span class="eq-badge st-pm me-1"></span> <small class="me-3" data-i18n="leg_pm">PM/Test</small>
                <span class="eq-badge st-idle me-1"></span> <small data-i18n="leg_idle">Idle</small>
            </div>
        </div>
    </div>
    <div class="eas-table-container shadow-sm" id="eas-grid-container"></div>
</div>

<!-- FDC 指標看板 -->
<div id="page-fdc" class="page-section">
    <h4 class="mb-3" data-i18n="fdc_title">FDC 指標看板</h4>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover text-center align-middle mb-0 text-nowrap">
                <thead class="table-light"><tr><th class="text-start bg-light" data-i18n="fdc_table_title">指標項目</th><th>DF1</th><th>DF2</th><th>ET1</th></tr></thead>
                <tbody><tr><td class="text-start fw-bold" data-i18n="fdc_i1">1. No Spec Recipe 統計</td><td><span class="text-primary fw-bold">143</span></td><td>314</td><td>141</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<!-- 權限申請 -->
<div id="page-apply" class="page-section">
    <h4 class="mb-3" data-i18n="apply_title">系統權限申請中心</h4>
    <div class="card shadow-sm border-0 col-md-6">
        <div class="card-body"><button class="btn btn-primary" data-i18n="apply_btn">送出審核</button></div>
    </div>
</div>


