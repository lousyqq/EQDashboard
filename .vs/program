        // --- 2. 動態系統看板初始化 ---
        function getCustomMenus() {
            let menusStr = localStorage.getItem('umc_custom_menus_v3');
            if (!menusStr) {
                const defaultMenus = [
                    { id: 'menu_eas_main', name: 'EAS', i18nKey: 'menu_eas_main', targetPage: 'page-eas-main', icon: 'fas fa-desktop', fabs: ['12A'], reqAuth: true, parentId: null },
                    { id: 'menu_eqas', name: 'EQAS', i18nKey: 'menu_eqas', targetPage: 'page-eqas', icon: 'fas fa-chart-bar', fabs: ['12A'], reqAuth: true, parentId: null },
                    { id: 'menu_daily', name: '日管', i18nKey: 'menu_daily', targetPage: 'page-daily', icon: 'fas fa-calendar-check', fabs: ['12A'], reqAuth: true, parentId: null },
                    { id: 'menu_ze', name: 'ZE 強化防禦', i18nKey: 'menu_ze', icon: 'fas fa-shield-alt', fabs: ['12A'], reqAuth: true, parentId: null },
                    { id: 'menu_ze_mnop', name: 'MNOP', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze' },
                    { id: 'menu_ze_wl', name: 'WL', reqAuth: true, parentId: 'menu_ze' },
                    { id: 'menu_ze_wl_scale', name: 'Scaling', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze_wl' },
                    { id: 'menu_ze_wl_noscale', name: 'Non Scaling', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze_wl' },
                    { id: 'menu_ze_bsl', name: 'BSL', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze' },
                    { id: 'menu_ze_extra', name: 'Extra Sensor', targetPage: 'page-ze-content', reqAuth: true, parentId: 'menu_ze' },
                    { id: 'menu_eas_12m', name: '12M EAS 機況', i18nKey: 'menu_eas_12m', targetPage: 'page-eas', icon: 'fas fa-th', fabs: ['12M'], reqAuth: true, parentId: null },
                    { id: 'menu_fdc', name: 'FDC 指標看板', i18nKey: 'menu_fdc', targetPage: 'page-fdc', icon: 'fas fa-table', fabs: ['12A', '12i'], reqAuth: true, parentId: null }
                ];
                localStorage.setItem('umc_custom_menus_v3', JSON.stringify(defaultMenus));
                return defaultMenus;
            }
            return JSON.parse(menusStr);
        }

        function generateSidebarMenuItem(menu, allMenus, level) {
            const children = allMenus.filter(m => m.parentId === menu.id);
            const hasChildren = children.length > 0;
            
            let isVisible = true;
            let isLocked = false;
            
            if (menu.reqAuth) {
                if (!currentUser) isVisible = false;
                else if (!currentUser.isAdmin) isLocked = true;
            }
            if (menu.fabs && menu.fabs.length > 0 && !menu.fabs.includes(currentFab)) {
                isVisible = false;
            }
            if (!isVisible) return '';

            let defaultIcon = '';
            if (level === 0) defaultIcon = hasChildren ? 'fa-folder text-warning' : 'fa-link text-primary';
            else if (level === 1 && hasChildren) defaultIcon = 'fa-folder-open text-warning';
            else defaultIcon = 'fa-angle-right text-muted';

            const lockIcon = isLocked ? '<i class="fas fa-lock ms-auto auth-icon text-warning"></i>' : '';
            const iconHtml = menu.icon ? `<i class="${menu.icon} fa-fw me-2"></i>` : `<i class="fas ${defaultIcon} fa-fw me-2"></i>`;
            const padClass = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5 ms-2' : '');
            
            const i18nAttr = menu.i18nKey ? `data-i18n="${menu.i18nKey}"` : '';
            const displayName = menu.i18nKey ? `<span ${i18nAttr}>${i18n[currentLang][menu.i18nKey] || menu.name}</span>` : `<span>${menu.name}</span>`;

            // 行為設定：加入 App Grid 判斷
            let actionAttr = '';
            if (isLocked) {
                actionAttr = `onclick="authModal.show(); return false;"`;
            } else if (hasChildren) {
                actionAttr = `data-bs-toggle="collapse" data-bs-target="#collapse-${menu.id}" aria-expanded="false"`;
            } else if (menu.menuMode === 'app_grid') {
                actionAttr = `onclick="openAppGridPage('${menu.id}', '${menu.name}', this)"`;
            } else if (menu.url) { 
                if (menu.target === 'blank') {
                    actionAttr = `onclick="window.open('${menu.url}', '_blank')"`;
                } else if (menu.target === 'popup') {
                    actionAttr = `onclick="window.open('${menu.url}', 'popup_${menu.id}', 'width=1100,height=700,top=100,left=150,toolbar=no,menubar=no,scrollbars=yes,resizable=yes'); return false;"`;
                } else {
                    actionAttr = `onclick="openDynamicIframe('${menu.url}', '${menu.name}', this)"`;
                }
            } else if (menu.targetPage) {
                actionAttr = `onclick="navTo('${menu.targetPage}', this, '${menu.name}')"`;
            }

            if (hasChildren) {
                let html = `
                <div class="menu-item ${isLocked ? 'locked' : ''} ${padClass}" id="menu-el-${menu.id}" ${actionAttr}>
                    ${iconHtml} ${displayName}
                    ${lockIcon}
                    ${!isLocked ? '<i class="fas fa-chevron-down ms-auto dropdown-icon" style="font-size: 0.8rem;"></i>' : ''}
                </div>
                <div class="collapse" id="collapse-${menu.id}">
                    <div class="bg-light py-1 ${level === 0 ? 'border-bottom' : ''}">
                `;
                children.forEach(child => html += generateSidebarMenuItem(child, allMenus, level + 1));
                html += `</div></div>`;
                return html;
            } else {
                return `<div class="menu-item ${isLocked ? 'locked' : ''} ${padClass}" id="menu-el-${menu.id}" ${actionAttr}>${iconHtml} ${displayName} ${lockIcon}</div>`;
            }
        }

        function renderSidebarMenus() {
            let html = '';
            const menus = getCustomMenus();
            const rootMenus = menus.filter(m => !m.parentId);
            rootMenus.forEach(root => html += generateSidebarMenuItem(root, menus, 0));
            document.getElementById('dynamic-sidebar-menus').innerHTML = html;
        }

        // --- 3. 語系與廠區切換 ---
        let currentLang = 'zh';
        function changeLanguage(lang) {
            currentLang = lang;
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18n[lang] && i18n[lang][key]) el.innerHTML = i18n[lang][key];
            });
            const langCodes = { 'zh': 'ZH', 'en': 'EN', 'ja': 'JA' };
            document.getElementById('current-lang-code').innerText = langCodes[lang];
            document.querySelectorAll('.lang-check').forEach(el => el.classList.add('d-none'));
            document.getElementById('check-' + lang).classList.remove('d-none');
        }

        let currentFab = '12A';
        function switchFab(fab) {
            currentFab = fab;
            document.querySelectorAll('.fab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('btn-fab-' + fab).classList.add('active');
            document.getElementById('dash-fab-display').innerText = fab;

            if (fab === '12M') {
                document.querySelector('.eas-table-container').style.borderTopColor = "#dd4b39";
                currentLang = 'ja';
            } else if (fab === '12i') {
                currentLang = 'en';
            } else if (fab === '12A') {
                currentLang = 'zh';
            }

            renderSidebarMenus();
            changeLanguage(currentLang); 
            
            navTo('page-home', document.querySelector('[onclick*="page-home"]'));
            if(currentUser && fab === '12M') renderEasBoard(); 
        }

        // --- 4. 登入邏輯與動態權限 ---
        let currentUser = null;
        const authModal = new bootstrap.Modal(document.getElementById('authModal'));

        document.getElementById('empPwd').addEventListener('keypress', function (e) { if (e.key === 'Enter') doLogin(); });
        document.getElementById('empId').addEventListener('keypress', function (e) { if (e.key === 'Enter') doLogin(); });

        function doLogin() {
            const empId = document.getElementById('empId').value.trim().toLowerCase();
            if (empId === 'admin') currentUser = { id: 'admin', name: 'Admin User', role: 'System Admin', isAdmin: true };
            else if (empId === 'user') currentUser = { id: 'user', name: 'General User', role: 'Basic User', isAdmin: false };
            else { alert(currentLang === 'zh' ? "請輸入 admin 或 user" : "Please enter admin or user"); return; }

            const countKey = 'eq_login_count_' + currentUser.id;
            let loginCount = parseInt(localStorage.getItem(countKey) || '0');
            localStorage.setItem(countKey, ++loginCount);

            document.getElementById('user-name').innerText = currentUser.name;
            document.getElementById('user-role').innerText = currentUser.role;
            document.getElementById('dash-role-display').innerText = currentUser.role;
            document.getElementById('user-login-count').innerText = loginCount;
            document.getElementById('login-count-container').style.display = 'block';

            const manageDash = document.getElementById('menu-manage-dash');
            if (currentUser.isAdmin) {
                manageDash.style.display = 'block';
                manageDash.classList.remove('locked');
            } else {
                manageDash.style.display = 'none';
                manageDash.classList.add('locked');
            }

            document.getElementById('login-overlay').style.opacity = '0';
            setTimeout(() => { document.getElementById('login-overlay').style.display = 'none'; }, 500);
            
            switchFab('12A'); 
            renderCustomMenus(); 
        }

        function logout() {
            currentUser = null;
            document.getElementById('login-count-container').style.display = 'none';
            document.getElementById('login-overlay').style.display = 'flex';
            setTimeout(() => { document.getElementById('login-overlay').style.opacity = '1'; }, 50);
            
            const manageDash = document.getElementById('menu-manage-dash');
            if (manageDash) {
                manageDash.style.display = 'none';
                manageDash.classList.add('locked');
            }

            document.getElementById('main-iframe').src = "";
            renderSidebarMenus(); 
            navTo('page-home', document.querySelector('[onclick*="page-home"]')); 
        }

        function navTo(pageId, element, subTitle = '') {
            if (element && element.classList.contains('locked')) { authModal.show(); return; }
            
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            if(element) element.classList.add('active');
            
            document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');

            if (pageId === 'page-ze-content') {
                document.getElementById('ze-sub-title').innerText = subTitle;
                document.getElementById('ze-sub-desc').innerText = subTitle;
            }
        }

        function goToApply() { authModal.hide(); navTo('page-apply', document.querySelector('[onclick="navTo(\'page-apply\', this)"]')); }

        // --- 5. 動態看板管理與 App Grid 模式 ---
        function toggleMenuMode() {
            const mode = document.querySelector('input[name="menuMode"]:checked').value;
            const urlGroup = document.getElementById('urlGroup');
            const targetGroup = document.getElementById('targetGroup');
            
            if (mode === 'app_grid') {
                urlGroup.style.display = 'none';
                targetGroup.style.display = 'none';
            } else {
                urlGroup.style.display = 'block';
                targetGroup.style.display = 'block';
            }
        }

        function renderCustomMenus() {
            const menus = getCustomMenus();
            const tableBody = document.getElementById('customMenuTableBody');
            const parentSelect = document.getElementById('customMenuParent');
            
            tableBody.innerHTML = '';
            parentSelect.innerHTML = '<option value="">無 (作為主選單)</option>';

            const rootMenus = menus.filter(m => !m.parentId);
            
            rootMenus.forEach(root => {
                const level1 = menus.filter(m => m.parentId === root.id);
                parentSelect.innerHTML += `<option value="${root.id}">${root.name}</option>`;
                tableBody.innerHTML += generateManageTableRow(root, 0, level1.length > 0);
                
                level1.forEach(l1 => {
                    const level2 = menus.filter(m => m.parentId === l1.id);
                    parentSelect.innerHTML += `<option value="${l1.id}">&nbsp;&nbsp;&nbsp;-- ${l1.name} (子選單)</option>`;
                    tableBody.innerHTML += generateManageTableRow(l1, 1, level2.length > 0);
                    
                    level2.forEach(l2 => {
                        tableBody.innerHTML += generateManageTableRow(l2, 2, false);
                    });
                });
            });
        }

        function generateManageTableRow(menu, level, hasChildren) {
            let padding = level === 1 ? 'ps-4' : (level === 2 ? 'ps-5' : 'ps-3');
            
            let iconHtml = '';
            if (menu.icon) {
                iconHtml = `<i class="${menu.icon} me-2 text-primary"></i>`;
            } else {
                let defaultIcon = level === 0 ? (hasChildren ? 'fas fa-folder text-warning' : 'fas fa-link text-primary') : 'fas fa-angle-right text-muted';
                if(level === 2) defaultIcon = 'fas fa-minus text-muted ms-2';
                iconHtml = `<i class="${defaultIcon} me-2"></i>`;
            }
            
            let levelBadge = level === 0 ? '<span class="badge bg-secondary">主選單</span>' : (level === 1 ? '<span class="badge bg-light text-dark border">子選單</span>' : '<span class="badge bg-light text-muted border">次子選單</span>');
            
            let fabsBadge = '';
            if (menu.fabs && menu.fabs.length > 0) {
                fabsBadge = menu.fabs.map(f => `<span class="badge bg-secondary me-1" style="font-size:0.65rem;">${f}</span>`).join('');
            } else {
                fabsBadge = `<span class="badge bg-dark me-1" style="font-size:0.65rem;">全廠區</span>`;
            }

            let urlDisplay = '';
            if (menu.menuMode === 'app_grid') {
                urlDisplay = `<span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2"><i class="fas fa-th-large me-1"></i>App 應用集合</span>`;
            } else {
                let targetBadge = '';
                if (menu.url) {
                    if (menu.target === 'blank') targetBadge = '<span class="badge bg-info ms-1">新分頁</span>';
                    else if (menu.target === 'popup') targetBadge = '<span class="badge bg-warning text-dark ms-1">彈出視窗</span>';
                    else targetBadge = '<span class="badge bg-success ms-1">內嵌</span>';
                }
                urlDisplay = menu.url ? `<a href="${menu.url}" target="_blank">${menu.url}</a> ${targetBadge}` : (menu.targetPage ? `<span class="text-info small"><i class="fas fa-microchip me-1"></i>內部頁面</span>` : '-');
            }

            return `
                <tr>
                    <td class="${padding} fw-bold">${iconHtml} ${menu.name}</td>
                    <td>${levelBadge}</td>
                    <td>${fabsBadge}</td>
                    <td class="text-muted small">${urlDisplay}</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="editCustomMenu('${menu.id}')"><i class="fas fa-edit"></i></button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteCustomMenu('${menu.id}')"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            `;
        }

        function editCustomMenu(id) {
            const menus = getCustomMenus();
            const menu = menus.find(m => m.id === id);
            if (!menu) return;

            document.getElementById('editMenuId').value = menu.id;
            document.getElementById('customMenuName').value = menu.name;
            document.getElementById('customMenuUrl').value = menu.url || '';
            document.getElementById('customMenuParent').value = menu.parentId || '';
            document.getElementById('customMenuTarget').value = menu.target || 'iframe';
            document.getElementById('customMenuIcon').value = menu.icon || '';
            
            document.querySelectorAll('.fab-check').forEach(cb => {
                if (!menu.fabs || menu.fabs.length === 0) {
                    cb.checked = true;
                } else {
                    cb.checked = menu.fabs.includes(cb.value);
                }
            });
            
            document.getElementById(menu.menuMode === 'app_grid' ? 'modeAppGrid' : 'modeLink').checked = true;
            toggleMenuMode();
            
            document.getElementById('cancelMenuBtn').style.display = 'block';
            document.getElementById('submitMenuBtn').innerHTML = '<i class="fas fa-save me-1"></i> 更新';
            document.querySelector('#main-content').scrollTo(0,0);
        }

        function saveCustomMenu(event) {
            event.preventDefault();
            const id = document.getElementById('editMenuId').value;
            const mode = document.querySelector('input[name="menuMode"]:checked').value;
            const name = document.getElementById('customMenuName').value.trim();
            const url = document.getElementById('customMenuUrl').value.trim();
            const parentId = document.getElementById('customMenuParent').value;
            const target = document.getElementById('customMenuTarget').value;
            const icon = document.getElementById('customMenuIcon').value;

            const checkedFabs = Array.from(document.querySelectorAll('.fab-check:checked')).map(cb => cb.value);
            if (checkedFabs.length === 0) {
                alert('請至少選擇一個顯示廠區！');
                return;
            }

            if (!name) return;

            let menus = getCustomMenus();
            
            if (parentId && id) {
                let currentParent = menus.find(m => m.id === parentId);
                while(currentParent) {
                    if (currentParent.id === id) { alert("錯誤：不能將看板設定為自己子選單的子選單！"); return; }
                    currentParent = menus.find(m => m.id === currentParent.parentId);
                }
            }
            
            if (id) {
                const index = menus.findIndex(m => m.id === id);
                if (index > -1) {
                    menus[index].name = name;
                    menus[index].menuMode = mode;
                    menus[index].url = mode === 'app_grid' ? '' : url;
                    if (url && mode !== 'app_grid') menus[index].targetPage = null; 
                    menus[index].parentId = parentId || null;
                    menus[index].target = target;
                    menus[index].icon = icon;
                    menus[index].fabs = checkedFabs;
                    menus[index].i18nKey = null; 
                }
            } else {
                menus.push({
                    id: 'dyn_' + Date.now(),
                    name: name,
                    menuMode: mode,
                    url: mode === 'app_grid' ? '' : url,
                    parentId: parentId || null,
                    target: target,
                    icon: icon,
                    fabs: checkedFabs,
                    reqAuth: true 
                });
            }

            localStorage.setItem('umc_custom_menus_v3', JSON.stringify(menus));
            resetMenuForm();
            renderCustomMenus();
            renderSidebarMenus(); 
        }

        function resetMenuForm() {
            document.getElementById('menuForm').reset();
            document.getElementById('editMenuId').value = '';
            document.getElementById('modeLink').checked = true;
            toggleMenuMode();
            document.querySelectorAll('.fab-check').forEach(cb => cb.checked = true);
            document.getElementById('customMenuTarget').value = 'iframe';
            document.getElementById('customMenuIcon').value = '';
            document.getElementById('cancelMenuBtn').style.display = 'none';
            document.getElementById('submitMenuBtn').innerHTML = '<i class="fas fa-plus me-1"></i> 新增看板';
        }

        function deleteCustomMenu(id) {
            if(!confirm('確定要刪除此看板嗎？若有子選單也會一併被遞迴刪除。')) return;
            let menus = getCustomMenus();
            
            let idsToDelete = new Set([id]);
            let size = 0;
            while(idsToDelete.size > size) {
                size = idsToDelete.size;
                menus.forEach(m => {
                    if(idsToDelete.has(m.parentId)) idsToDelete.add(m.id);
                });
            }
            
            menus = menus.filter(m => !idsToDelete.has(m.id));
            localStorage.setItem('umc_custom_menus_v3', JSON.stringify(menus));

            // 一併刪除所屬的 APP 捷徑
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
            apps = apps.filter(a => !idsToDelete.has(a.menuId));
            localStorage.setItem('umc_custom_apps_v1', JSON.stringify(apps));
            
            renderCustomMenus();
            renderSidebarMenus();
        }

        function openDynamicIframe(url, title, element) {
            if (!url) return;
            navTo('page-iframe', element);
            document.getElementById('iframe-title').innerHTML = `<i class="fas fa-globe me-2"></i>${title}`;
            document.getElementById('main-iframe').src = url;
            document.getElementById('iframe-popout-btn').onclick = () => window.open(url, '_blank');
        }

        // --- 6. 新增功能：App Grid 內部網頁邏輯 ---
        let currentAppMenuId = null;
        let currentAppIconBase64 = null;
        const defaultAppIcon = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64"><rect width="64" height="64" rx="14" fill="%23002b5e"/><text x="32" y="38" font-family="Arial" font-weight="bold" font-size="20" fill="white" text-anchor="middle">APP</text></svg>';
        const appGridModal = new bootstrap.Modal(document.getElementById('appGridModal'));

        function openAppGridPage(menuId, menuName, element) {
            navTo('page-app-grid', element);
            document.getElementById('app-grid-title').innerText = menuName;
            currentAppMenuId = menuId;
            renderAppGridList();
        }

        function renderAppGridList() {
            const container = document.getElementById('app-grid-container');
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
            apps = apps.filter(a => a.menuId === currentAppMenuId);

            let html = '';
            apps.forEach(app => {
                html += `
                <div class="app-card">
                    ${currentUser && currentUser.isAdmin ? `
                    <div class="app-actions">
                        <button class="app-btn-action app-btn-edit" onclick="editAppItem('${app.id}')" title="編輯"><i class="fas fa-pen"></i></button>
                        <button class="app-btn-action app-btn-delete" onclick="deleteAppItem('${app.id}')" title="刪除"><i class="fas fa-times"></i></button>
                    </div>` : ''}
                    <div class="app-icon-box" onclick="window.open('${app.url}', '_blank')">
                        <img src="${app.icon || defaultAppIcon}" class="app-icon-img">
                    </div>
                    <div class="app-name" onclick="window.open('${app.url}', '_blank')">${app.name}</div>
                </div>`;
            });

            if (currentUser && currentUser.isAdmin) {
                html += `
                <div class="app-card app-add" onclick="openAddAppModal()">
                    <div class="app-icon-box app-add-box">
                        <i class="fas fa-plus"></i>
                    </div>
                    <div class="app-name text-muted">新增網頁</div>
                </div>`;
            }

            container.innerHTML = html;
        }

        function openAddAppModal() {
            document.getElementById('appForm').reset();
            document.getElementById('appIdInput').value = '';
            document.getElementById('appIconPreview').style.display = 'none';
            currentAppIconBase64 = null;
            document.querySelector('#appGridModal .modal-title').innerHTML = '<i class="fas fa-plus-square me-2"></i>新增 APP 網頁';
            appGridModal.show();
        }

        // 新增編輯 APP 彈出邏輯
        function editAppItem(appId) {
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
            let app = apps.find(a => a.id === appId);
            if(!app) return;
            
            document.getElementById('appForm').reset();
            document.getElementById('appIdInput').value = app.id;
            document.getElementById('appName').value = app.name;
            document.getElementById('appUrl').value = app.url;
            
            currentAppIconBase64 = app.icon === defaultAppIcon ? null : app.icon;
            
            const preview = document.getElementById('appIconPreview');
            if(app.icon && app.icon !== defaultAppIcon) {
                preview.src = app.icon;
                preview.style.display = 'inline-block';
            } else {
                preview.style.display = 'none';
                preview.src = '';
            }
            
            document.querySelector('#appGridModal .modal-title').innerHTML = '<i class="fas fa-edit me-2"></i>編輯 APP 網頁';
            appGridModal.show();
        }

        function handleAppIconUpload(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    currentAppIconBase64 = e.target.result;
                    const preview = document.getElementById('appIconPreview');
                    preview.src = currentAppIconBase64;
                    preview.style.display = 'inline-block';
                }
                reader.readAsDataURL(file);
            }
        }

        function saveAppItem(event) {
            event.preventDefault();
            const id = document.getElementById('appIdInput').value;
            const name = document.getElementById('appName').value.trim();
            const url = document.getElementById('appUrl').value.trim();

            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
            
            if (id) {
                // 編輯更新模式
                const index = apps.findIndex(a => a.id === id);
                if (index > -1) {
                    apps[index].name = name;
                    apps[index].url = url;
                    apps[index].icon = currentAppIconBase64 || defaultAppIcon;
                }
            } else {
                // 新增模式
                apps.push({
                    id: 'app_' + Date.now(),
                    menuId: currentAppMenuId,
                    name: name,
                    url: url,
                    icon: currentAppIconBase64 || defaultAppIcon
                });
            }

            localStorage.setItem('umc_custom_apps_v1', JSON.stringify(apps));
            appGridModal.hide();
            renderAppGridList();
        }

        function deleteAppItem(appId) {
            if(!confirm('確定要移除此 APP 捷徑嗎？')) return;
            let apps = JSON.parse(localStorage.getItem('umc_custom_apps_v1')) || [];
            apps = apps.filter(a => a.id !== appId);
            localStorage.setItem('umc_custom_apps_v1', JSON.stringify(apps));
            renderAppGridList();
        }

        // --- 7. EAS 模擬資料 ---
        function renderEasBoard() {
            const now = new Date();
            document.getElementById('eas-time').innerText = now.toLocaleString();
            const container = document.getElementById('eas-grid-container');
            container.innerHTML = ''; 
            const prefixPool = ['M23', 'YUKA', 'TOKYO', 'SAPP', 'OSAK'];
            const eqData = [
                { area: '12M-D1', sec: 'SEC_01', prefix: prefixPool.slice(0,2) },
                { area: '12M-D2', sec: 'SEC_02', prefix: prefixPool.slice(2,4) },
                { area: '12M-ET', sec: 'SEC_ET', prefix: prefixPool.slice(4,5) }
            ];
            const statusClasses = ['st-run', 'st-run', 'st-run', 'st-down', 'st-pm', 'st-idle'];
            let htmlStr = '';

            eqData.forEach(row => {
                htmlStr += `<div class="eas-row"><div class="eas-col-area">${row.area}</div><div class="eas-col-sec">${row.sec}</div><div class="eas-col-items">`;
                row.prefix.forEach(prefix => {
                    let chamberCount = Math.floor(Math.random() * 5) + 5; 
                    for(let i=1; i<=chamberCount; i++) {
                        let sClass = statusClasses[Math.floor(Math.random() * statusClasses.length)];
                        let cNum = i < 10 ? '0'+i : i;
                        htmlStr += `<span class="eq-badge ${sClass}" title="${prefix}/C${cNum}">${prefix}/C${cNum}</span>`;
                    }
                });
                htmlStr += `</div></div>`;
            });
            container.innerHTML = htmlStr;
        }

        // 系統啟動初始化
        renderSidebarMenus();
        changeLanguage('zh');

    </script>
</body>
</html>